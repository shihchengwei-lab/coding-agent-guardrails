#!/usr/bin/env python3
"""Deterministic corridor and completion gates plus a factual cost report.

PreToolUse denies product edits without a valid corridor or outside its Paths.
Stop rechecks the persistent facts that must be true before completion:
configured typecheck/test commands pass, new dependencies are justified, all
product changes remain inside the corridor, and trivial work changes at most one
product file. PRUNED.md records rejected routes; it never waives a red gate.

Trusted checks are loaded from <git-dir>/guardrails/config.json and executed
as argv with shell=False. SLIME_TEST_TIMEOUT may lower their timeout ceiling.
  SLIME_PUBSPEC        alternate pubspec path (default pubspec.yaml).
"""
import json
import hashlib
import os
import re
import subprocess
import sys

PUBSPEC = os.environ.get("SLIME_PUBSPEC", "pubspec.yaml")


def read_input():
    try:
        return json.load(sys.stdin)
    except Exception:
        return {}


def git(cwd, *args):
    # core.quotepath=false: git's default C-quoting turns non-ASCII paths into
    # "lib/caf\303\251.dart", which can never match a corridor glob and would
    # false-block — the one thing an L2 gate must not do.
    # encoding="utf-8": git emits UTF-8 path bytes; text=True alone decodes
    # with the locale codepage (e.g. cp936 on Chinese Windows), which
    # mangles non-ASCII paths and re-opens the same false-block.
    try:
        r = subprocess.run(
            ["git", "-c", "core.quotepath=false", *args],
            cwd=cwd,
            capture_output=True,
            text=True,
            encoding="utf-8",
            errors="replace",
            timeout=30,
        )
        return r.stdout if r.returncode == 0 else ""
    except Exception:
        return ""


def is_git(cwd):
    return bool(git(cwd, "rev-parse", "--is-inside-work-tree").strip())


# --------------------------------------------------------------------------
# L2 — PreToolUse corridor gate
# --------------------------------------------------------------------------
TEMPLATE_ID = "example-feature"
TEMPLATE_GLOBS = {"lib/feature/example/**", "test/feature/example/**"}
RIGOR_LEVELS = {"trivial", "normal", "high"}
RIGOR_REQUIRED_SECTIONS = {
    "trivial": ("outcome", "paths", "stop condition"),
    "normal": (
        "outcome",
        "paths",
        "evidence",
        "stop condition",
    ),
    "high": (
        "outcome",
        "paths",
        "evidence",
        "stop condition",
        "high-risk controls",
    ),
}


def corridor_id(cwd):
    path = os.path.join(cwd, ".slime", "corridor.md")
    try:
        with open(path, encoding="utf-8") as f:
            for line in f:
                m = re.match(r"#\s*Corridor:\s*(.+)", line.strip())
                if m:
                    return m.group(1).strip()
    except OSError:
        return None
    return None


def corridor_sections(cwd):
    """Parse ``##`` sections once for rigor validation and path matching.

    Values are stripped, non-empty source lines.  Section names are normalized
    to lower case because the Markdown is author-written, while the required
    shape remains deterministic enough for the L2 gate.
    """
    path = os.path.join(cwd, ".slime", "corridor.md")
    sections = {}
    current = None
    try:
        with open(path, encoding="utf-8") as f:
            for raw in f:
                stripped = raw.strip()
                heading = re.match(r"##\s+(.+?)\s*$", stripped)
                if heading:
                    current = " ".join(heading.group(1).lower().split())
                    sections.setdefault(current, [])
                    continue
                if current is not None and stripped:
                    sections[current].append(stripped)
    except OSError:
        return {}
    return sections


def corridor_rigor(cwd, sections=None):
    """Return explicit rigor or an invalid sentinel/raw value."""
    sections = corridor_sections(cwd) if sections is None else sections
    if "rigor" not in sections:
        return "<missing>"
    values = [
        line
        for line in sections.get("rigor", [])
        if not line.startswith("<!--")
    ]
    if not values:
        return "<empty>"
    if len(values) != 1:
        return "<multiple values>"
    return values[0].strip().lower()


def section_has_labeled_item(sections, section, label):
    pattern = re.compile(r"-\s*" + re.escape(label) + r"\s*\S", re.IGNORECASE)
    return any(pattern.match(line) for line in sections.get(section, []))


def corridor_problem(cwd):
    """Return a reason string if the corridor is missing/invalid, else None.

    Only unambiguous signals block: missing file, missing header, the template
    id, an empty Paths list, or paths still pointing at the template example.
    """
    path = os.path.join(cwd, ".slime", "corridor.md")
    if not os.path.exists(path):
        return ".slime/corridor.md is missing"
    cid = corridor_id(cwd)
    if not cid:
        return ".slime/corridor.md has no '# Corridor: <id>' header"
    if cid == TEMPLATE_ID:
        return ".slime/corridor.md is still the template (id 'example-feature')"
    globs = corridor_globs(cwd)
    if not globs:
        return ".slime/corridor.md has an empty '## Paths' list"
    if any(glob.strip() in {"*", "**", "**/*"} for glob in globs):
        return ".slime/corridor.md contains a match-all path instead of a corridor"
    if any(
        glob.startswith("/")
        or re.match(r"^[A-Za-z]:[/\\]", glob)
        or ".." in glob.replace("\\", "/").split("/")
        for glob in globs
    ):
        return ".slime/corridor.md Paths must stay inside the repository"
    if any(g in TEMPLATE_GLOBS for g in globs):
        return ".slime/corridor.md still lists the template example paths"

    sections = corridor_sections(cwd)
    rigor = corridor_rigor(cwd, sections)
    if rigor == "<missing>":
        return (
            ".slime/corridor.md requires an explicit Rigor migration before "
            "product work can continue"
        )
    if rigor not in RIGOR_LEVELS:
        if rigor == "<empty>":
            return ".slime/corridor.md has an empty Rigor section"
        return (
            ".slime/corridor.md has unknown rigor "
            + repr(rigor)
            + "; expected trivial, normal, or high"
        )

    for required in RIGOR_REQUIRED_SECTIONS[rigor]:
        if not sections.get(required):
            display = " ".join(word.capitalize() for word in required.split())
            return f".slime/corridor.md rigor {rigor} requires a non-empty '## {display}' section"

    if rigor in {"normal", "high"}:
        if not section_has_labeled_item(sections, "evidence", "Supports:"):
            return ".slime/corridor.md Evidence requires a non-empty 'Supports:' item"
        if not section_has_labeled_item(sections, "evidence", "Would falsify:"):
            return ".slime/corridor.md Evidence requires a non-empty 'Would falsify:' item"

    if rigor == "high":
        for label in ("Failure mode:", "Rollback:", "Independent check:"):
            if not section_has_labeled_item(sections, "high-risk controls", label):
                return (
                    ".slime/corridor.md High-risk Controls requires a non-empty '"
                    + label
                    + "' item"
                )
    primary = stop_check_ids(cwd)
    manual = stop_manual(cwd)
    if not primary and not manual:
        return ".slime/corridor.md Stop Condition requires Check: or Manual:"
    if rigor == "high" and not primary:
        return ".slime/corridor.md high rigor requires at least one primary Check:"
    if rigor == "high" and not independent_check_id(cwd):
        return ".slime/corridor.md high rigor requires Independent check:"

    if primary or rigor == "high":
        _, config_error = load_trusted_checks(cwd)
        if config_error:
            return config_error
    return None


# Repo-metadata files: not product code, no real frontier to compute, so the
# corridor concept doesn't apply. Matched by basename so a nested .gitignore
# (which git itself honours at any depth) is also exempt. README.md is
# deliberately NOT here — it describes product behaviour and is a real edit
# target. Keep the list conservative; widening it is a one-line change.
META_BASENAMES = {
    ".gitignore",
    ".gitattributes",
    ".editorconfig",
    "LICENSE",
    "LICENSE.md",
    "LICENSE.txt",
    "CHANGELOG.md",
}


def normalize_target(cwd, path):
    if not path:
        return None
    path = path.strip()
    if path in {"/dev/null", "NUL"}:
        return None
    fp = path
    absolute = fp if os.path.isabs(fp) else os.path.join(cwd, fp)
    try:
        return os.path.relpath(absolute, cwd).replace(os.sep, "/")
    except ValueError:
        return None


def target_paths(cwd, data):
    """Return every file target from Claude Edit/Write or Codex apply_patch."""
    tool_input = data.get("tool_input") or {}
    direct = tool_input.get("file_path") or tool_input.get("path")
    if direct:
        target = normalize_target(cwd, direct)
        return [target] if target else []

    if data.get("tool_name") != "apply_patch":
        return []
    command = tool_input.get("command")
    if not isinstance(command, str):
        return []
    targets = []
    pattern = re.compile(
        r"^\*\*\* (?:(?:Add|Update|Delete) File|Move to):\s*(.+?)\s*$",
        re.MULTILINE,
    )
    for match in pattern.finditer(command):
        target = normalize_target(cwd, match.group(1))
        if target and target not in targets:
            targets.append(target)
    return targets


def is_exempt_target(path):
    return path == ".slime" or path.startswith(".slime/") or (
        os.path.basename(path) in META_BASENAMES
    )


def deny_pretool(reason):
    print(
        json.dumps(
            {
                "hookSpecificOutput": {
                    "hookEventName": "PreToolUse",
                    "permissionDecision": "deny",
                    "permissionDecisionReason": "Slime Coding: " + reason,
                }
            }
        )
    )


def corridor_gate(data):
    cwd = data.get("cwd") or os.getcwd()
    targets = target_paths(cwd, data)
    if not targets:
        deny_pretool(
            "could not identify the edit target from the hook payload; "
            "refusing an unscoped write"
        )
        sys.exit(0)
    external = [
        path
        for path in targets
        if path == ".." or path.startswith("../")
    ]
    if external:
        deny_pretool(
            f"{', '.join(external)} is outside the repository and cannot be authorized by a corridor"
        )
        sys.exit(0)
    product_targets = [path for path in targets if not is_exempt_target(path)]
    # .slime artifacts must bootstrap the corridor itself; conservative repo
    # metadata is also outside the product boundary.
    if not product_targets:
        sys.exit(0)
    problem = corridor_problem(cwd)
    if problem:
        out = {
            "hookSpecificOutput": {
                "hookEventName": "PreToolUse",
                "permissionDecision": "deny",
                "permissionDecisionReason": (
                    "Slime Coding: " + problem + ". Define the Meeting Corridor "
                    "before editing — run /slime-corridor (or the slime-navigate "
                    "skill). No valid corridor = no evidence for where the "
                    "minimal change should land."
                ),
            }
        }
        print(json.dumps(out))
        sys.exit(0)
    globs = corridor_globs(cwd)
    outside = [
        target
        for target in product_targets
        if not any(glob_match(target, pattern) for pattern in globs)
    ]
    if outside:
        deny_pretool(
            f"{', '.join(outside)} is outside the corridor paths. Update the corridor with "
            "new evidence before editing, or keep the change inside its declared boundary."
        )
    sys.exit(0)


# --------------------------------------------------------------------------
# L2 — Stop: new-dependency gate
# --------------------------------------------------------------------------
def parse_deps(text):
    # Tolerant of real-world pubspec formatting: a trailing comment on the
    # dependencies: line and any consistent indent width (2 or 4 spaces) —
    # the old "exactly two spaces" match silently disabled the gate on
    # 4-space files. Direct deps are the entries at the block's first indent
    # level; deeper lines (sdk: flutter) are attributes, not deps.
    deps = set()
    in_block = False
    base_indent = None
    for line in text.splitlines():
        if re.match(r"^dependencies:\s*(#.*)?$", line):
            in_block = True
            base_indent = None
            continue
        if in_block:
            if re.match(r"^\S", line):  # next top-level key ends the block
                break
            m = re.match(r"^(\s+)([\w-]+):", line)
            if m:
                indent = len(m.group(1).expandtabs())
                if base_indent is None:
                    base_indent = indent
                if indent == base_indent:
                    deps.add(m.group(2))
    return deps


def pubspec_new_dependencies(cwd):
    head = git(cwd, "show", "HEAD:" + PUBSPEC)
    if not head:
        # No baseline at HEAD (fresh repo, or manifest not yet committed) — we
        # cannot tell new deps from existing ones, so degrade rather than
        # false-block. L2 gates must never fire on an ambiguous signal.
        return []
    try:
        with open(os.path.join(cwd, PUBSPEC), encoding="utf-8") as f:
            cur = f.read()
    except OSError:
        return []
    return sorted(parse_deps(cur) - parse_deps(head))


def requirement_name(spec):
    match = re.match(r"\s*([A-Za-z0-9_.-]+)", spec)
    return match.group(1).lower() if match else None


def dependency_names(path, text):
    name = os.path.basename(path)
    if name == "package.json":
        try:
            data = json.loads(text)
        except (TypeError, ValueError):
            return set()
        deps = set()
        for group in (
            "dependencies",
            "devDependencies",
            "peerDependencies",
            "optionalDependencies",
        ):
            values = data.get(group)
            if isinstance(values, dict):
                deps.update(str(key).lower() for key in values)
        return deps
    if name.startswith("requirements") and name.endswith(".txt"):
        deps = set()
        for line in text.splitlines():
            stripped = line.strip()
            if not stripped or stripped.startswith(("#", "-")):
                continue
            package = requirement_name(stripped)
            if package:
                deps.add(package)
        return deps
    if name in {"pyproject.toml", "Cargo.toml"}:
        try:
            import tomllib

            data = tomllib.loads(text)
        except (ImportError, ValueError):
            return set()
        if name == "Cargo.toml":
            deps = set()
            for group in ("dependencies", "dev-dependencies", "build-dependencies"):
                values = data.get(group)
                if isinstance(values, dict):
                    deps.update(str(key).lower() for key in values)
            return deps
        deps = set()
        project = data.get("project")
        if isinstance(project, dict):
            for spec in project.get("dependencies", []):
                package = requirement_name(str(spec))
                if package:
                    deps.add(package)
            optional = project.get("optional-dependencies")
            if isinstance(optional, dict):
                for specs in optional.values():
                    if isinstance(specs, list):
                        for spec in specs:
                            package = requirement_name(str(spec))
                            if package:
                                deps.add(package)
        poetry = data.get("tool", {}).get("poetry", {})
        if isinstance(poetry, dict):
            for group in ("dependencies", "dev-dependencies"):
                values = poetry.get(group)
                if isinstance(values, dict):
                    deps.update(str(key).lower() for key in values if key != "python")
        return deps
    if name == "go.mod":
        deps = set()
        in_block = False
        for line in text.splitlines():
            stripped = line.strip()
            if stripped == "require (":
                in_block = True
                continue
            if in_block and stripped == ")":
                in_block = False
                continue
            if stripped.startswith("require "):
                parts = stripped.split()
                if len(parts) >= 2:
                    deps.add(parts[1])
            elif in_block and stripped and not stripped.startswith("//"):
                deps.add(stripped.split()[0])
        return deps
    return set()


def dependency_manifest_paths(cwd):
    return dependency_manifest_paths_for(cwd, None)


def is_dependency_manifest(path):
    supported = {PUBSPEC, "package.json", "pyproject.toml", "Cargo.toml", "go.mod"}
    return path == PUBSPEC or os.path.basename(path) in supported or (
        os.path.basename(path).startswith("requirements") and path.endswith(".txt")
    )


def dependency_manifest_paths_for(cwd, baseline):
    touched, new_files = changed_paths(cwd, baseline)
    return sorted(
        {
            path
            for path in touched + new_files
            if is_dependency_manifest(path)
        }
    )


def new_dependencies(cwd, baseline=None):
    if baseline is None:
        added = [f"{PUBSPEC}: {name}" for name in pubspec_new_dependencies(cwd)]
    else:
        added = []
    for path in dependency_manifest_paths_for(cwd, baseline):
        if baseline is None and path == PUBSPEC:
            continue
        try:
            with open(os.path.join(cwd, path), encoding="utf-8") as f:
                current = f.read()
        except OSError:
            continue
        if baseline is not None and path in baseline.get("dependency_baseline", {}):
            old_names = set(baseline["dependency_baseline"][path])
        else:
            head = baseline.get("head") if baseline is not None else "HEAD"
            old_text = git(cwd, "show", f"{head}:{path}") if head else ""
            old_names = dependency_names(path, old_text)
        for package in sorted(
            dependency_names(path, current) - old_names
        ):
            added.append(f"{path}: {package}")
    return sorted(added)


def justified_dependencies(cwd):
    justified = set()
    for line in corridor_sections(cwd).get("evidence", []):
        match = re.match(r"-\s*Dependency:\s*(\S+)", line, re.IGNORECASE)
        if match:
            justified.add(match.group(1).lower())
    return justified


def dependency_package(record):
    return record.rsplit(": ", 1)[-1].lower()


CHECK_ID_RE = re.compile(r"^[a-z0-9_-]{1,64}$")


def stop_check_ids(cwd):
    result = []
    for line in corridor_sections(cwd).get("stop condition", []):
        match = re.match(r"-\s*Check:\s*(\S+)\s*$", line, re.IGNORECASE)
        if match:
            result.append(match.group(1).lower())
    return result


def stop_manual(cwd):
    for line in corridor_sections(cwd).get("stop condition", []):
        if re.match(r"-\s*Manual:\s*\S", line, re.IGNORECASE):
            return True
    return False


def independent_check_id(cwd):
    for line in corridor_sections(cwd).get("high-risk controls", []):
        match = re.match(r"-\s*Independent check:\s*(\S+)\s*$", line, re.IGNORECASE)
        if match:
            return match.group(1).lower()
    return None


def guardrails_config_path(cwd):
    git_dir = git(cwd, "rev-parse", "--absolute-git-dir").strip()
    if not git_dir:
        return None
    return os.path.join(git_dir, "guardrails", "config.json")


def load_trusted_checks(cwd):
    path = guardrails_config_path(cwd)
    if not path:
        return {}, "could not resolve <git-dir>/guardrails/config.json"
    try:
        with open(path, encoding="utf-8") as handle:
            data = json.load(handle)
    except (OSError, ValueError) as exc:
        return {}, f"trusted check config.json could not be read: {exc}"
    if not isinstance(data, dict) or type(data.get("schema")) is not int or data.get("schema") != 1:
        return {}, "trusted check config.json requires integer schema 1"
    raw_checks = data.get("checks")
    if not isinstance(raw_checks, dict):
        return {}, "trusted check config.json requires a checks object"
    checks = {}
    for check_id, value in raw_checks.items():
        if not isinstance(check_id, str) or not CHECK_ID_RE.fullmatch(check_id):
            return {}, f"trusted check ID {check_id!r} must match [a-z0-9_-] and be 1-64 characters"
        if not isinstance(value, dict):
            return {}, f"trusted check {check_id!r} must be an object"
        argv = value.get("argv")
        if (
            not isinstance(argv, list)
            or not argv
            or any(not isinstance(item, str) or not item for item in argv)
        ):
            return {}, f"trusted check {check_id!r} argv must be a non-empty string array"
        timeout = value.get("timeout_seconds", 600)
        if type(timeout) is not int or not 1 <= timeout <= 3600:
            return {}, f"trusted check {check_id!r} timeout_seconds must be an integer from 1 to 3600"
        checks[check_id] = {"argv": list(argv), "timeout_seconds": timeout}
    return checks, None


def run_trusted_check(cwd, check, check_id):
    try:
        ceiling = int(os.environ.get("SLIME_TEST_TIMEOUT", "3600"))
        if not 1 <= ceiling <= 3600:
            raise ValueError("SLIME_TEST_TIMEOUT must be from 1 to 3600")
        timeout = min(check["timeout_seconds"], ceiling)
        r = subprocess.run(
            check["argv"], cwd=cwd, shell=False, capture_output=True, text=True,
            timeout=timeout,
        )
        return r.returncode, (r.stdout or r.stderr or "")
    except subprocess.TimeoutExpired:
        return 124, f"trusted check {check_id} timed out after {timeout} seconds"
    except Exception as exc:
        return 126, f"trusted check {check_id} could not run: {exc}"


# --------------------------------------------------------------------------
# L3 — Stop: cost report
# --------------------------------------------------------------------------
def corridor_globs(cwd):
    globs = []
    sections = corridor_sections(cwd)
    for line in sections.get("paths", []):
        match = re.match(r"-\s+(.+)", line)
        if match:
            globs.append(match.group(1).strip())
    return globs


def head_changed_paths(cwd):
    touched = [n for n in git(cwd, "diff", "HEAD", "--name-only").splitlines() if n]
    new_files = [
        u
        for u in git(cwd, "ls-files", "--others", "--exclude-standard").splitlines()
        if u
    ]
    return touched, new_files


def current_head(cwd):
    return git(cwd, "rev-parse", "HEAD").strip() or None


def _stream_sha256(path):
    digest = hashlib.sha256()
    with open(path, "rb") as f:
        while chunk := f.read(1024 * 1024):
            digest.update(chunk)
    return digest.hexdigest()


def index_signatures(cwd):
    """Read the full index once and map repo-relative paths to stage records."""
    result = {}
    for record in git(cwd, "ls-files", "--stage", "-z").split("\0"):
        if not record or "\t" not in record:
            continue
        metadata, path = record.split("\t", 1)
        result[path] = metadata
    return result


def file_signature(cwd, path, index=None):
    absolute = os.path.join(cwd, path)
    if os.path.islink(absolute):
        worktree = "symlink:" + os.readlink(absolute)
    elif os.path.isfile(absolute):
        try:
            worktree = "file:" + _stream_sha256(absolute)
        except OSError as exc:
            worktree = "unreadable:" + type(exc).__name__
    elif os.path.exists(absolute):
        worktree = "other"
    else:
        worktree = "missing"
    index = index_signatures(cwd) if index is None else index
    return {"worktree": worktree, "index": index.get(path, "")}


def dirty_signatures(cwd):
    touched, new_files = head_changed_paths(cwd)
    index = index_signatures(cwd)
    return {
        path: file_signature(cwd, path, index)
        for path in sorted(set(touched + new_files))
    }


def corridor_digest(cwd):
    path = os.path.join(cwd, ".slime", "corridor.md")
    try:
        with open(path, "rb") as f:
            return hashlib.sha256(f.read()).hexdigest()
    except OSError:
        return None


def git_dir(cwd):
    raw = git(cwd, "rev-parse", "--git-dir").strip()
    if not raw:
        return None
    return raw if os.path.isabs(raw) else os.path.abspath(os.path.join(cwd, raw))


def baseline_token(data):
    value = data.get("turn_id") or data.get("session_id")
    return value if isinstance(value, str) and value.strip() else None


def baseline_path(cwd, data, create=False):
    token = baseline_token(data)
    root = git_dir(cwd)
    if not token or not root:
        return None
    safe = hashlib.sha256(token.encode("utf-8")).hexdigest()[:24]
    parent = os.path.join(root, "slime", "turns", safe)
    if create:
        os.makedirs(parent, exist_ok=True)
    return os.path.join(parent, "baseline.json")


def dependency_snapshot(cwd, dirty):
    snapshot = {}
    for path in dirty:
        if not is_dependency_manifest(path):
            continue
        try:
            with open(os.path.join(cwd, path), encoding="utf-8") as f:
                snapshot[path] = sorted(dependency_names(path, f.read()))
        except OSError:
            snapshot[path] = []
    return snapshot


def record_baseline(data):
    cwd = data.get("cwd") or os.getcwd()
    if not is_git(cwd):
        return
    path = baseline_path(cwd, data, create=True)
    if not path or os.path.exists(path):
        return
    dirty = dirty_signatures(cwd)
    state = {
        "schema": 1,
        "head": current_head(cwd),
        "dirty_paths": dirty,
        "dependency_baseline": dependency_snapshot(cwd, dirty),
        "corridor_hash": corridor_digest(cwd),
    }
    tmp = path + f".tmp-{os.getpid()}"
    try:
        with open(tmp, "w", encoding="utf-8") as f:
            json.dump(state, f, sort_keys=True)
            f.write("\n")
        os.replace(tmp, path)
    finally:
        try:
            if os.path.exists(tmp):
                os.unlink(tmp)
        except OSError:
            pass


def load_baseline(cwd, data):
    path = baseline_path(cwd, data)
    if not path:
        return None
    try:
        with open(path, encoding="utf-8") as f:
            state = json.load(f)
    except (OSError, ValueError):
        return None
    if not isinstance(state, dict) or state.get("schema") != 1:
        return None
    if not isinstance(state.get("dirty_paths"), dict):
        return None
    return state


def clear_baselines(cwd, data):
    tokens = [data.get("turn_id"), data.get("session_id")]
    for token in tokens:
        if not isinstance(token, str) or not token:
            continue
        probe = dict(data)
        probe["turn_id"] = token
        probe["session_id"] = None
        path = baseline_path(cwd, probe)
        if not path:
            continue
        try:
            os.unlink(path)
            os.rmdir(os.path.dirname(path))
        except OSError:
            pass


def changed_paths(cwd, baseline=None):
    if baseline is None:
        return head_changed_paths(cwd)

    before = baseline.get("dirty_paths", {})
    after = dirty_signatures(cwd)
    delta = {
        path
        for path in set(before) | set(after)
        if before.get(path) != after.get(path)
    }
    old_head = baseline.get("head")
    new_head = current_head(cwd)
    if old_head and new_head and old_head != new_head:
        delta.update(
            path
            for path in git(cwd, "diff", "--name-only", f"{old_head}..{new_head}").splitlines()
            if path
        )
    current_untracked = set(
        path
        for path in git(cwd, "ls-files", "--others", "--exclude-standard").splitlines()
        if path
    )
    new_files = sorted(delta & current_untracked)
    touched = sorted(delta - current_untracked)
    return touched, new_files


def glob_to_regex(pattern):
    """git-style glob -> regex: * and ? never cross /, **/ spans zero+ dirs.

    fnmatch's * crosses /, which made a corridor of lib/*.dart silently
    admit lib/vendor/deep.dart.
    """
    parts = []
    i = 0
    n = len(pattern)
    while i < n:
        ch = pattern[i]
        if ch == "*":
            if pattern.startswith("**/", i):
                parts.append("(?:[^/]+/)*")
                i += 3
            elif pattern.startswith("**", i):
                parts.append(".*")
                i += 2
            else:
                parts.append("[^/]*")
                i += 1
        elif ch == "?":
            parts.append("[^/]")
            i += 1
        else:
            parts.append(re.escape(ch))
            i += 1
    return re.compile("".join(parts) + r"\Z")


def glob_match(path, pattern):
    if pattern.endswith("/**"):
        prefix = pattern[:-3].rstrip("/")
        return path == prefix or path.startswith(prefix + "/")
    return glob_to_regex(pattern).match(path) is not None


def out_of_corridor_files(cwd, baseline=None):
    globs = corridor_globs(cwd)
    if not globs:
        return []
    touched, new_files = changed_paths(cwd, baseline)
    out_corr = []
    for n in touched + new_files:
        # .slime/ artifacts aren't scope creep: corridor edits are tracked
        # separately (corridor changed), and PRUNED.md updates are required.
        if n.startswith(".slime/"):
            continue
        # Repo metadata is not product code, so the default strict corridor gate
        # should not turn harmless config hygiene into a hard stop.
        if os.path.basename(n) in META_BASENAMES:
            continue
        if not any(glob_match(n, g) for g in globs):
            out_corr.append(n)
    return out_corr


def l3_report(cwd, baseline=None):
    touched, new_files = changed_paths(cwd, baseline)
    globs = corridor_globs(cwd)
    out_corr = out_of_corridor_files(cwd, baseline)
    rigor = corridor_rigor(cwd)
    lines = [
        "Slime Coding — cost report:",
        f"  corridor rigor: {rigor}",
        f"  touched files: {len(touched)}",
        f"  new files: {len(new_files)}",
    ]
    if globs:
        suffix = f" -> {', '.join(out_corr[:10])}" if out_corr else ""
        lines.append(f"  out-of-corridor files: {len(out_corr)}{suffix}")
    else:
        lines.append("  out-of-corridor: (no '## Paths' defined in corridor.md)")
    # The corridor gate always lets .slime/ through (to avoid a bootstrap
    # deadlock), so widening the corridor mid-task is possible. That can be
    # legitimate new evidence, so we don't block — but surface it for the user.
    corridor_changed = (
        corridor_digest(cwd) != baseline.get("corridor_hash")
        if baseline is not None
        else bool(git(cwd, "status", "--porcelain", "--", ".slime/corridor.md").strip())
    )
    lines.append(f"  corridor changed this session: {'yes' if corridor_changed else 'no'}")
    if baseline is None:
        lines.append("  turn baseline: unavailable (HEAD fallback; coverage partial)")
    else:
        lines.append("  turn baseline: captured")
    return "\n".join(lines)


def product_paths(cwd, baseline=None):
    touched, new_files = changed_paths(cwd, baseline)
    return sorted(
        {
            path
            for path in touched + new_files
            if not path.startswith(".slime/")
            and os.path.basename(path) not in META_BASENAMES
        }
    )


def stop_blocks(cwd, baseline=None):
    blocks = []
    products = product_paths(cwd, baseline)
    problem = corridor_problem(cwd)
    if problem and products:
        blocks.append(
            "Product code changed but "
            + problem
            + ". Restore or complete .slime/corridor.md before finishing: "
            + ", ".join(products[:10])
        )

    allowed_dependencies = justified_dependencies(cwd)
    dependencies = [
        record
        for record in new_dependencies(cwd, baseline)
        if dependency_package(record) not in allowed_dependencies
    ]
    if dependencies:
        blocks.append(
            "New dependency added without corridor evidence: "
            + ", ".join(dependencies)
            + ". Remove it or add '- Dependency: <package> — <reason>' to "
            ".slime/corridor.md Evidence."
        )

    if not problem:
        checks, config_error = load_trusted_checks(cwd)
        primary_ids = stop_check_ids(cwd)
        independent_id = (
            independent_check_id(cwd) if corridor_rigor(cwd) == "high" else None
        )
        referenced = primary_ids + ([independent_id] if independent_id else [])
        if referenced and config_error:
            blocks.append(config_error)
        else:
            unknown = [check_id for check_id in referenced if check_id not in checks]
            if unknown:
                blocks.append("Unknown check ID in trusted config: " + ", ".join(unknown))
            duplicate = independent_id in primary_ids if independent_id else False
            if duplicate:
                blocks.append("Independent check ID must differ from primary Check IDs.")
            if independent_id and independent_id in checks:
                independent_argv = tuple(checks[independent_id]["argv"])
                if any(
                    check_id in checks
                    and tuple(checks[check_id]["argv"]) == independent_argv
                    for check_id in primary_ids
                ):
                    blocks.append(
                        "Independent check has the same argv as a primary check."
                    )
            if not unknown and not duplicate and not any(
                "same argv" in block.lower() for block in blocks
            ):
                for check_id in primary_ids:
                    result = run_trusted_check(cwd, checks[check_id], check_id)
                    if result[0] != 0:
                        blocks.append(
                            f"Trusted check {check_id} failed or could not run "
                            f"(exit {result[0]}).\n\n{result[1][:1500]}"
                        )
                if independent_id:
                    result = run_trusted_check(
                        cwd, checks[independent_id], independent_id
                    )
                    if result[0] != 0:
                        blocks.append(
                            "Independent check failed or could not run (exit "
                            + str(result[0])
                            + ").\n\n"
                            + result[1][:1500]
                        )

    outside = out_of_corridor_files(cwd, baseline)
    if outside:
        blocks.append(
            "Out-of-corridor product edits detected: "
            + ", ".join(outside[:10])
            + ". Move the change inside Paths or update the corridor with the "
            "new evidence before editing."
        )

    if corridor_rigor(cwd) == "trivial" and len(products) > 1:
        blocks.append(
            "A trivial corridor may change one product file; found "
            + str(len(products))
            + ": "
            + ", ".join(products[:10])
            + ". Use normal rigor or narrow the change."
        )

    return blocks


def stop(data):
    cwd = data.get("cwd") or os.getcwd()
    if not is_git(cwd):
        sys.exit(0)

    # Re-run every gate on every Stop. Retrying Stop does not turn red evidence
    # into completion.
    baseline = load_baseline(cwd, data)
    blocks = stop_blocks(cwd, baseline)
    report = l3_report(cwd, baseline)
    if blocks:
        print(json.dumps({"decision": "block", "reason": "\n\n".join(blocks) + "\n\n" + report}))
        sys.exit(0)
    clear_baselines(cwd, data)
    print(json.dumps({"systemMessage": report}))
    sys.exit(0)


def post_tool(data):
    if data.get("tool_name") != "Bash":
        return
    cwd = data.get("cwd") or os.getcwd()
    if not is_git(cwd):
        return
    baseline = load_baseline(cwd, data)
    outside = out_of_corridor_files(cwd, baseline)
    products = product_paths(cwd, baseline)
    problem = corridor_problem(cwd)
    reasons = []
    if problem and products:
        reasons.append(
            "Shell command produced product edits while " + problem + "."
        )
    if outside:
        reasons.append(
            "Shell command produced out-of-corridor product edits: "
            + ", ".join(outside[:10])
            + "."
        )
    if reasons:
        print(
            json.dumps(
                {
                    "decision": "block",
                    "reason": (
                        " ".join(reasons)
                        + " Revert them or update the corridor with new evidence. "
                        "The shell side effect already occurred; this hook cannot undo it."
                    ),
                }
            )
        )


def main():
    data = read_input()
    event = data.get("hook_event_name")
    if event in {"SessionStart", "UserPromptSubmit"}:
        record_baseline(data)
    elif event == "PreToolUse":
        corridor_gate(data)
    elif event == "PostToolUse":
        post_tool(data)
    elif event == "Stop":
        stop(data)
    sys.exit(0)


if __name__ == "__main__":
    main()

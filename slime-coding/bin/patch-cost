#!/usr/bin/env python3
"""Low-friction Guardrails hook coordinator and internal CLI.

Intent and approval state live under the Git directory. Repository Markdown
never authorizes execution. Trusted checks are loaded from
<git-dir>/guardrails/config.json and run as argv with shell=False.
"""
import argparse
import json
import hashlib
import os
import re
import secrets
import subprocess
import sys
import time

PUBSPEC = os.environ.get("SLIME_PUBSPEC", "pubspec.yaml")
REVIEW_ARTIFACT = ".guardrails/review.json"
HIGH_RISK_SEGMENTS = {
    "auth", "login", "oauth", "session", "jwt", "permission",
    "credential", "secret", "migration", "migrations", "terraform",
    "kubernetes", "helm", "deploy", "deployment", "infrastructure",
}


def read_input():
    try:
        return json.load(sys.stdin)
    except Exception:
        return {}


def git(cwd, *args):
    # core.quotepath=false: git's default C-quoting turns non-ASCII paths into
    # "lib/caf\303\251.dart", which can never match a corridor glob and would
    # false-block — the one thing an L2 gate must not do.
    # encoding="utf-8": git emits UTF-8 path bytes; text=True alone decodes
    # with the locale codepage (e.g. cp936 on Chinese Windows), which
    # mangles non-ASCII paths and re-opens the same false-block.
    try:
        r = subprocess.run(
            ["git", "-c", "core.quotepath=false", *args],
            cwd=cwd,
            capture_output=True,
            text=True,
            encoding="utf-8",
            errors="replace",
            timeout=30,
        )
        return r.stdout if r.returncode == 0 else ""
    except Exception:
        return ""


def is_git(cwd):
    return bool(git(cwd, "rev-parse", "--is-inside-work-tree").strip())


def normalize_target(cwd, path):
    if not path:
        return None
    path = path.strip()
    if path in {"/dev/null", "NUL"}:
        return None
    fp = path
    absolute = fp if os.path.isabs(fp) else os.path.join(cwd, fp)
    try:
        return os.path.relpath(absolute, cwd).replace(os.sep, "/")
    except ValueError:
        return None


def target_paths(cwd, data):
    """Return every file target from Claude Edit/Write or Codex apply_patch."""
    tool_input = data.get("tool_input") or {}
    direct = tool_input.get("file_path") or tool_input.get("path")
    if direct:
        target = normalize_target(cwd, direct)
        return [target] if target else []

    if data.get("tool_name") != "apply_patch":
        return []
    command = tool_input.get("command")
    if not isinstance(command, str):
        return []
    targets = []
    pattern = re.compile(
        r"^\*\*\* (?:(?:Add|Update|Delete) File|Move to):\s*(.+?)\s*$",
        re.MULTILINE,
    )
    for match in pattern.finditer(command):
        target = normalize_target(cwd, match.group(1))
        if target and target not in targets:
            targets.append(target)
    return targets


def is_exempt_target(path):
    return path == REVIEW_ARTIFACT


def deny_pretool(reason):
    print(
        json.dumps(
            {
                "hookSpecificOutput": {
                    "hookEventName": "PreToolUse",
                    "permissionDecision": "deny",
                    "permissionDecisionReason": "Slime Coding: " + reason,
                }
            }
        )
    )


def is_dependency_manifest(path):
    # Case-insensitive: delivery_risk lowercases paths before calling and
    # "Cargo.toml" must still match (it used to slip through as high-risk
    # exempt); Windows filesystems are case-insensitive anyway.
    # Kept aligned with Corridor CI's DEPENDENCY_GLOBS: anything Corridor
    # floors to high risk must also be high risk locally, or the artifact
    # underreports and the PR gate rejects it.
    supported = {
        PUBSPEC.lower(),
        "package.json", "package-lock.json", "npm-shrinkwrap.json",
        "pnpm-lock.yaml", "yarn.lock", "bun.lock", "bun.lockb",
        "pyproject.toml", "setup.py", "poetry.lock", "uv.lock",
        "pipfile", "pipfile.lock",
        "cargo.toml", "cargo.lock",
        "go.mod", "go.sum",
        "gemfile", "gemfile.lock",
    }
    basename = os.path.basename(path).lower()
    return path == PUBSPEC or basename in supported or (
        basename.startswith("requirements") and basename.endswith(".txt")
    )
CHECK_ID_RE = re.compile(r"^[a-z0-9_-]{1,64}$")


def guardrails_config_path(cwd):
    git_dir = git(cwd, "rev-parse", "--absolute-git-dir").strip()
    if not git_dir:
        return None
    return os.path.join(git_dir, "guardrails", "config.json")


def load_trusted_checks(cwd):
    path = guardrails_config_path(cwd)
    if not path:
        return {}, "could not resolve <git-dir>/guardrails/config.json"
    try:
        with open(path, encoding="utf-8") as handle:
            data = json.load(handle)
    except (OSError, ValueError) as exc:
        return {}, f"trusted check config.json could not be read: {exc}"
    if not isinstance(data, dict) or type(data.get("schema")) is not int or data.get("schema") != 1:
        return {}, "trusted check config.json requires integer schema 1"
    raw_checks = data.get("checks")
    if not isinstance(raw_checks, dict):
        return {}, "trusted check config.json requires a checks object"
    checks = {}
    for check_id, value in raw_checks.items():
        if not isinstance(check_id, str) or not CHECK_ID_RE.fullmatch(check_id):
            return {}, f"trusted check ID {check_id!r} must match [a-z0-9_-] and be 1-64 characters"
        if not isinstance(value, dict):
            return {}, f"trusted check {check_id!r} must be an object"
        argv = value.get("argv")
        if (
            not isinstance(argv, list)
            or not argv
            or any(not isinstance(item, str) or not item for item in argv)
        ):
            return {}, f"trusted check {check_id!r} argv must be a non-empty string array"
        timeout = value.get("timeout_seconds", 600)
        if type(timeout) is not int or not 1 <= timeout <= 3600:
            return {}, f"trusted check {check_id!r} timeout_seconds must be an integer from 1 to 3600"
        checks[check_id] = {"argv": list(argv), "timeout_seconds": timeout}
    return checks, None


def run_trusted_check(cwd, check, check_id):
    try:
        ceiling = int(os.environ.get("SLIME_TEST_TIMEOUT", "3600"))
        if not 1 <= ceiling <= 3600:
            raise ValueError("SLIME_TEST_TIMEOUT must be from 1 to 3600")
        timeout = min(check["timeout_seconds"], ceiling)
        r = subprocess.run(
            check["argv"], cwd=cwd, shell=False, capture_output=True, text=True,
            timeout=timeout,
        )
        return r.returncode, (r.stdout or r.stderr or "")
    except subprocess.TimeoutExpired:
        return 124, f"trusted check {check_id} timed out after {timeout} seconds"
    except Exception as exc:
        return 126, f"trusted check {check_id} could not run: {exc}"


def head_changed_paths(cwd):
    touched = [n for n in git(cwd, "diff", "HEAD", "--name-only").splitlines() if n]
    new_files = [
        u
        for u in git(cwd, "ls-files", "--others", "--exclude-standard").splitlines()
        if u
    ]
    return touched, new_files


def current_head(cwd):
    return git(cwd, "rev-parse", "HEAD").strip() or None


def _stream_sha256(path):
    digest = hashlib.sha256()
    with open(path, "rb") as f:
        while chunk := f.read(1024 * 1024):
            digest.update(chunk)
    return digest.hexdigest()


def index_signatures(cwd):
    """Read the full index once and map repo-relative paths to stage records."""
    result = {}
    for record in git(cwd, "ls-files", "--stage", "-z").split("\0"):
        if not record or "\t" not in record:
            continue
        metadata, path = record.split("\t", 1)
        result[path] = metadata
    return result


def file_signature(cwd, path, index=None):
    absolute = os.path.join(cwd, path)
    if os.path.islink(absolute):
        worktree = "symlink:" + os.readlink(absolute)
    elif os.path.isfile(absolute):
        try:
            worktree = "file:" + _stream_sha256(absolute)
        except OSError as exc:
            worktree = "unreadable:" + type(exc).__name__
    elif os.path.exists(absolute):
        worktree = "other"
    else:
        worktree = "missing"
    index = index_signatures(cwd) if index is None else index
    return {"worktree": worktree, "index": index.get(path, "")}


def dirty_signatures(cwd):
    touched, new_files = head_changed_paths(cwd)
    index = index_signatures(cwd)
    return {
        path: file_signature(cwd, path, index)
        for path in sorted(set(touched + new_files))
    }


def git_dir(cwd):
    raw = git(cwd, "rev-parse", "--git-dir").strip()
    if not raw:
        return None
    return raw if os.path.isabs(raw) else os.path.abspath(os.path.join(cwd, raw))


def _session_turn_path(cwd, session_id):
    root = git_dir(cwd)
    if not root:
        return None
    safe = hashlib.sha256(session_id.encode("utf-8")).hexdigest()[:24]
    return os.path.join(root, "guardrails", "sessions", safe + ".json")


def baseline_token(data, cwd=None, create=False):
    value = data.get("turn_id")
    if isinstance(value, str) and value.strip():
        return value
    session = data.get("session_id")
    if not isinstance(session, str) or not session.strip() or not cwd:
        return None
    state_path = _session_turn_path(cwd, session)
    if create:
        counter = 0
        try:
            with open(state_path, encoding="utf-8") as handle:
                counter = int(json.load(handle).get("counter", 0))
        except (OSError, ValueError, TypeError):
            pass
        token = hashlib.sha256(f"{session}\0{counter + 1}".encode("utf-8")).hexdigest()[:24]
        _atomic_json(state_path, {"schema": 1, "counter": counter + 1, "token": token})
        return token
    try:
        with open(state_path, encoding="utf-8") as handle:
            state = json.load(handle)
        token = state.get("token")
    except (OSError, ValueError, TypeError):
        return None
    return token if isinstance(token, str) and token else None


def baseline_path(cwd, data, create=False):
    token = baseline_token(data, cwd, create=create)
    root = git_dir(cwd)
    if not token or not root:
        return None
    safe = hashlib.sha256(token.encode("utf-8")).hexdigest()[:24]
    parent = os.path.join(root, "guardrails", "turns", safe)
    if create:
        os.makedirs(parent, exist_ok=True)
    return os.path.join(parent, "baseline.json")


def _baseline_path_for_token(cwd, token, create=False):
    root = git_dir(cwd)
    if not root or not token:
        return None
    safe = hashlib.sha256(token.encode("utf-8")).hexdigest()[:24]
    parent = os.path.join(root, "guardrails", "turns", safe)
    if create:
        os.makedirs(parent, exist_ok=True)
    return os.path.join(parent, "baseline.json")


def record_baseline(data):
    cwd = data.get("cwd") or os.getcwd()
    if not is_git(cwd):
        return
    path = baseline_path(cwd, data, create=True)
    if not path or os.path.exists(path):
        return
    dirty = dirty_signatures(cwd)
    turn_token = baseline_token(data, cwd)
    state = {
        "schema": 1,
        "head": current_head(cwd),
        "dirty_paths": dirty,
        "agentcam_turn_id": turn_token,
        "agentcam_ready": False,
    }
    tmp = path + f".tmp-{os.getpid()}"
    try:
        with open(tmp, "w", encoding="utf-8") as f:
            json.dump(state, f, sort_keys=True)
            f.write("\n")
        os.replace(tmp, path)
        state["agentcam_ready"] = _agentcam_hook(cwd, data, "hook-turn-start", turn_token)
        _atomic_json(path, state)
    finally:
        try:
            if os.path.exists(tmp):
                os.unlink(tmp)
        except OSError:
            pass


def _agentcam_hook(cwd, data, command, turn_token):
    if not turn_token:
        return False
    payload = dict(data)
    payload["cwd"] = str(cwd)
    payload["turn_id"] = turn_token
    try:
        result = subprocess.run(
            [sys.executable, "-m", "agentcam.cli", command],
            cwd=cwd,
            input=json.dumps(payload),
            capture_output=True,
            text=True,
            timeout=30,
        )
        return result.returncode == 0
    except (OSError, subprocess.TimeoutExpired):
        return False


def _agentcam_session_dir(cwd, turn_token):
    try:
        from agentcam.hooks import _safe_session_id
    except Exception:
        return None
    root = git_dir(cwd)
    return None if not root else os.path.join(root, "agentcam", "sessions", _safe_session_id(turn_token))


def _record_agentcam_checks(cwd, baseline, checks):
    turn_token = baseline.get("agentcam_turn_id")
    session_dir = _agentcam_session_dir(cwd, turn_token)
    if not session_dir or not os.path.isdir(session_dir):
        return False
    try:
        from agentcam.redaction import redact_argv
        from agentcam.git_state import compute_final_state_fingerprint
        from agentcam.verification import new_record_id, write_record
        final_state = compute_final_state_fingerprint(__import__("pathlib").Path(cwd))
        recorded_at = __import__("datetime").datetime.now(
            __import__("datetime").timezone.utc
        ).astimezone().isoformat()
        for check in checks:
            write_record(__import__("pathlib").Path(session_dir), {
                "record_id": new_record_id(),
                "command": " ".join(redact_argv(list(check["argv"]))),
                "exit_code": check["exit_code"],
                "duration_seconds": round(check["duration_ms"] / 1000, 3),
                "recorded_at": recorded_at,
                "state_fingerprint": final_state,
            })
        return True
    except Exception:
        return False


def _finalize_agentcam(cwd, data, baseline):
    root = git_dir(cwd)
    if not root:
        return None
    runs = os.path.join(root, "agentcam", "runs")
    before = set(os.listdir(runs)) if os.path.isdir(runs) else set()
    final_payload = dict(data)
    scope = read_delivery_scope(cwd)
    final_payload["declared_scope"] = scope.get("paths", [])
    if not _agentcam_hook(
        cwd, final_payload, "hook-turn-end", baseline.get("agentcam_turn_id")
    ):
        return None
    after = set(os.listdir(runs)) if os.path.isdir(runs) else set()
    created = sorted(after - before)
    if not created:
        # The hook succeeded but produced no run: the turn itself made no
        # git-visible change (e.g. all delivery work was committed in
        # earlier turns). That is a valid delivery with no turn capture,
        # not a failure — return an empty manifest so capture degrades to
        # partial/unavailable downstream.
        return {}
    if len(created) != 1:
        return None
    run_dir = os.path.join(runs, created[0])
    try:
        with open(os.path.join(run_dir, "manifest.json"), encoding="utf-8") as handle:
            manifest = json.load(handle)
    except (OSError, ValueError):
        return None
    return manifest if isinstance(manifest, dict) else None


def load_baseline(cwd, data):
    path = baseline_path(cwd, data)
    if not path:
        return None
    try:
        with open(path, encoding="utf-8") as f:
            state = json.load(f)
    except (OSError, ValueError):
        return None
    if not isinstance(state, dict) or state.get("schema") != 1:
        return None
    if not isinstance(state.get("dirty_paths"), dict):
        return None
    return state


def clear_baselines(cwd, data):
    path = baseline_path(cwd, data)
    if path:
        old_path = None
        try:
            with open(path, encoding="utf-8") as handle:
                old_token = json.load(handle).get("agentcam_turn_id")
            old_path = _baseline_path_for_token(cwd, old_token)
        except (OSError, ValueError, TypeError):
            pass
        try:
            os.unlink(path)
            os.rmdir(os.path.dirname(path))
        except OSError:
            pass
        if old_path and old_path != path:
            try:
                os.unlink(old_path)
                os.rmdir(os.path.dirname(old_path))
            except OSError:
                pass


def cleanup_session(cwd, data):
    session = data.get("session_id")
    if not isinstance(session, str) or not session:
        return
    path = _session_turn_path(cwd, session)
    try:
        os.unlink(path)
        os.rmdir(os.path.dirname(path))
    except OSError:
        pass


def changed_paths(cwd, baseline=None):
    if baseline is None:
        return head_changed_paths(cwd)

    before = baseline.get("dirty_paths", {})
    after = dirty_signatures(cwd)
    delta = {
        path
        for path in set(before) | set(after)
        if before.get(path) != after.get(path)
    }
    old_head = baseline.get("head")
    new_head = current_head(cwd)
    if old_head and new_head and old_head != new_head:
        delta.update(
            path
            for path in git(cwd, "diff", "--name-only", f"{old_head}..{new_head}").splitlines()
            if path
        )
    current_untracked = set(
        path
        for path in git(cwd, "ls-files", "--others", "--exclude-standard").splitlines()
        if path
    )
    new_files = sorted(delta & current_untracked)
    touched = sorted(delta - current_untracked)
    return touched, new_files


def glob_to_regex(pattern):
    """git-style glob -> regex: * and ? never cross /, **/ spans zero+ dirs.

    fnmatch's * crosses /, which made a corridor of lib/*.dart silently
    admit lib/vendor/deep.dart.
    """
    parts = []
    i = 0
    n = len(pattern)
    while i < n:
        ch = pattern[i]
        if ch == "*":
            if pattern.startswith("**/", i):
                parts.append("(?:[^/]+/)*")
                i += 3
            elif pattern.startswith("**", i):
                parts.append(".*")
                i += 2
            else:
                parts.append("[^/]*")
                i += 1
        elif ch == "?":
            parts.append("[^/]")
            i += 1
        else:
            parts.append(re.escape(ch))
            i += 1
    return re.compile("".join(parts) + r"\Z")


def glob_match(path, pattern):
    if pattern.endswith("/**"):
        prefix = pattern[:-3].rstrip("/")
        return path == prefix or path.startswith(prefix + "/")
    return glob_to_regex(pattern).match(path) is not None


# --------------------------------------------------------------------------
# Low-friction delivery scope and review artifact
# --------------------------------------------------------------------------
def _atomic_json(path, value):
    os.makedirs(os.path.dirname(path), exist_ok=True)
    temporary = path + f".tmp-{os.getpid()}-{secrets.token_hex(4)}"
    try:
        with open(temporary, "w", encoding="utf-8") as handle:
            json.dump(value, handle, indent=2, ensure_ascii=False, sort_keys=True)
            handle.write("\n")
        os.replace(temporary, path)
    finally:
        try:
            if os.path.exists(temporary):
                os.unlink(temporary)
        except OSError:
            pass


def delivery_key(cwd):
    branch = git(cwd, "symbolic-ref", "--quiet", "--short", "HEAD").strip()
    identity = branch or current_head(cwd) or "detached"
    return hashlib.sha256(identity.encode("utf-8")).hexdigest()[:24]


def delivery_state_dir(cwd):
    root = git_dir(cwd)
    if not root:
        return None
    return os.path.join(root, "guardrails", "deliveries", delivery_key(cwd))


def delivery_scope_path(cwd):
    parent = delivery_state_dir(cwd)
    return None if not parent else __import__("pathlib").Path(parent) / "scope.json"


def resolve_delivery_base(cwd):
    current_branch = git(cwd, "symbolic-ref", "--quiet", "--short", "HEAD").strip()
    candidates = []
    remote_head = git(cwd, "symbolic-ref", "--quiet", "refs/remotes/origin/HEAD").strip()
    if remote_head:
        candidates.append(remote_head)
    candidates += ["origin/main", "main", "origin/master", "master"]
    for candidate in candidates:
        short = candidate.removeprefix("refs/remotes/")
        if short == current_branch or candidate == current_branch:
            continue
        if not git(cwd, "rev-parse", "--verify", candidate).strip():
            continue
        base = git(cwd, "merge-base", "HEAD", candidate).strip()
        if base:
            return base
    return current_head(cwd)


def _approval_path(cwd):
    parent = delivery_state_dir(cwd)
    return None if not parent else os.path.join(parent, "approval.json")


def set_delivery_scope(cwd, outcome, paths):
    normalized = []
    for raw in paths:
        value = normalize_target(cwd, raw)
        if (
            not value
            or value == ".."
            or value.startswith("../")
            or value in {"*", "**", "**/*"}
        ):
            raise ValueError(f"invalid delivery scope path: {raw}")
        if value not in normalized:
            normalized.append(value)
    if not str(outcome).strip() or not normalized:
        raise ValueError("delivery scope requires an outcome and at least one path")
    path = delivery_scope_path(cwd)
    if path is None:
        raise ValueError("delivery scope requires a git repository")
    existing = read_delivery_scope(cwd)
    value = {
        "schema": 1,
        "base_commit": existing.get("base_commit") or resolve_delivery_base(cwd),
        "outcomes": [str(outcome).strip()],
        "paths": normalized,
        "changes": [],
    }
    _atomic_json(str(path), value)
    return value


def read_delivery_scope(cwd):
    path = delivery_scope_path(cwd)
    if path is None:
        return {}
    try:
        value = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, ValueError):
        return {}
    if not isinstance(value, dict) or value.get("schema") != 1:
        return {}
    return value


def add_delivery_scope(cwd, paths, reason):
    state = read_delivery_scope(cwd)
    if not state:
        raise ValueError("set the delivery scope before expanding it")
    if not str(reason).strip():
        raise ValueError("scope expansion requires a concrete reason")
    added = []
    current = list(state.get("paths") or [])
    for raw in paths:
        value = normalize_target(cwd, raw)
        if not value or value == ".." or value.startswith("../"):
            raise ValueError(f"invalid delivery scope path: {raw}")
        if value not in current:
            current.append(value)
            added.append(value)
    if added:
        state["paths"] = current
        changes = list(state.get("changes") or [])
        changes.append({"added": added, "reason": str(reason).strip()})
        state["changes"] = changes
        _atomic_json(str(delivery_scope_path(cwd)), state)
    return state


def scope_gate(data):
    cwd = data.get("cwd") or os.getcwd()
    targets = target_paths(cwd, data)
    if not targets:
        deny_pretool("could not identify the edit target; refusing an unscoped write")
        return False
    external = [path for path in targets if path == ".." or path.startswith("../")]
    if external:
        deny_pretool(f"{', '.join(external)} is outside the repository")
        return False
    products = [path for path in targets if not is_exempt_target(path)]
    if not products:
        return True
    scope = read_delivery_scope(cwd)
    globs = scope.get("paths") if isinstance(scope.get("paths"), list) else []
    if not globs:
        deny_pretool(
            "declare the intended edit before writing. Agent: run `guardrails "
            "internal scope set --outcome \"<observable result>\" --path <path>`."
        )
        return False
    outside = [
        path for path in products
        if not any(glob_match(path, pattern) for pattern in globs)
    ]
    if outside:
        deny_pretool(
            f"{', '.join(outside)} is outside the intended edit. Agent: run "
            "`guardrails internal scope add --path <path> --reason \"<evidence>\"` "
            "before editing it."
        )
        return False
    return True


def _delivery_products(cwd, baseline):
    return [path for path in product_paths(cwd, baseline) if path != REVIEW_ARTIFACT]


def delivery_changed_files(cwd, baseline):
    untracked = set(
        line for line in git(cwd, "ls-files", "--others", "--exclude-standard").splitlines()
        if line
    )
    paths = set(_delivery_products(cwd, baseline))
    scope = read_delivery_scope(cwd)
    base = scope.get("base_commit")
    head = current_head(cwd)
    if isinstance(base, str) and base and head and base != head:
        paths.update(
            line for line in git(cwd, "diff", "--name-only", f"{base}..{head}").splitlines()
            if line and line != REVIEW_ARTIFACT and not is_exempt_target(line)
        )
    result = []
    for path in sorted(paths):
        absolute = os.path.join(cwd, path)
        if path in untracked:
            status = "untracked"
        elif not os.path.lexists(absolute):
            status = "deleted"
        else:
            status = "modified"
        result.append({"path": path, "status": status})
    return result


def review_product_fingerprint(cwd, changed):
    digest = hashlib.sha256()
    for item in sorted(changed, key=lambda value: value["path"]):
        path = item["path"]
        digest.update(path.encode("utf-8", errors="surrogateescape"))
        digest.update(b"\0")
        absolute = os.path.join(cwd, path)
        try:
            if os.path.islink(absolute):
                content = b"symlink:" + os.readlink(absolute).encode(
                    "utf-8", errors="surrogateescape"
                )
            else:
                with open(absolute, "rb") as handle:
                    file_hash = hashlib.sha256()
                    while chunk := handle.read(1024 * 1024):
                        file_hash.update(chunk)
                    content = file_hash.digest()
                    digest.update(content)
                    digest.update(b"\0")
                    continue
            digest.update(hashlib.sha256(content).digest())
        except OSError:
            digest.update(b"<missing>")
        digest.update(b"\0")
    return digest.hexdigest()


def delivery_risk(changed):
    reasons = []
    level = "none-detected"
    for item in changed:
        path = item["path"].replace("\\", "/").lower()
        segments = set(filter(None, path.split("/")))
        if item.get("status") == "deleted":
            reasons.append("tracked file deleted")
        if path.startswith(".github/workflows/"):
            reasons.append("workflow changed")
        if is_dependency_manifest(path):
            reasons.append("dependency manifest changed")
        matched = sorted(segments & HIGH_RISK_SEGMENTS)
        if matched:
            reasons.append(matched[0] + " path changed")
    if reasons:
        level = "high"
    return level, list(dict.fromkeys(reasons))


def agentcam_path_risk(changed):
    """Return Agentcam's canonical path risk before finalizing its session."""
    try:
        from agentcam.models import ChangedFile
        from agentcam.scanner import scan_paths
    except Exception as exc:
        return None, [f"Agentcam risk classifier unavailable: {exc}"]
    status_map = {
        "deleted": "unstaged_deleted",
        "untracked": "untracked",
        "modified": "unstaged_modified",
    }
    try:
        flags = scan_paths([
            ChangedFile(
                path=item["path"],
                status=status_map.get(item.get("status"), "unstaged_modified"),
            )
            for item in changed
        ])
    except Exception as exc:
        return None, [f"Agentcam risk classifier failed: {exc}"]
    high = [flag.rule for flag in flags if flag.level == "HIGH"]
    medium = [flag.rule for flag in flags if flag.level == "MEDIUM"]
    if high:
        return "high", list(dict.fromkeys(high))
    if medium:
        return "medium", list(dict.fromkeys(medium))
    return "none-detected", []


def _read_approval(cwd):
    path = _approval_path(cwd)
    try:
        with open(path, encoding="utf-8") as handle:
            value = json.load(handle)
    except (OSError, ValueError, TypeError):
        return {}
    return value if isinstance(value, dict) else {}


def _pending_confirmation(cwd, fingerprint, reasons, turn_token, checks):
    current = _read_approval(cwd)
    if current.get("product_fingerprint") == fingerprint and current.get("nonce"):
        if current.get("checks") != checks:
            current["checks"] = checks
            _atomic_json(_approval_path(cwd), current)
        return current
    nonce = secrets.token_hex(3).upper()
    value = {
        "schema": 1,
        "nonce": nonce,
        "phrase": f"確認高風險變更 {nonce}",
        "product_fingerprint": fingerprint,
        "turn_token": turn_token,
        "reasons": reasons,
        "checks": checks,
        "confirmed": False,
    }
    _atomic_json(_approval_path(cwd), value)
    return value


def accept_high_risk_prompt(cwd, data):
    prompt = data.get("prompt") or data.get("user_prompt")
    if not isinstance(prompt, str):
        return False
    pending = _read_approval(cwd)
    if not pending or pending.get("confirmed"):
        return False
    if prompt.strip() != pending.get("phrase"):
        return False
    current_token = baseline_token(data, cwd)
    old_token = pending.get("turn_token")
    if current_token and old_token and current_token != old_token:
        old_path = _baseline_path_for_token(cwd, old_token)
        new_path = _baseline_path_for_token(cwd, current_token, create=True)
        try:
            with open(old_path, "rb") as source:
                blob = source.read()
            temporary = new_path + f".tmp-{os.getpid()}"
            with open(temporary, "wb") as target:
                target.write(blob)
            os.replace(temporary, new_path)
        except OSError:
            return False
    pending["confirmed"] = True
    pending["confirmation_id"] = hashlib.sha256(
        (pending["phrase"] + "\0" + pending["product_fingerprint"]).encode("utf-8")
    ).hexdigest()
    pending.pop("phrase", None)
    _atomic_json(_approval_path(cwd), pending)
    return True


def _run_review_checks(cwd, fingerprint):
    checks = []
    started = time.monotonic()
    structural = subprocess.run(
        ["git", "diff", "--check"], cwd=cwd, capture_output=True, text=True
    )
    checks.append({
        "id": "structural",
        "argv": ["git", "diff", "--check"],
        "exit_code": structural.returncode,
        "duration_ms": round((time.monotonic() - started) * 1000),
        "state_fingerprint": fingerprint,
    })
    if structural.returncode:
        return checks, f"structural check failed:\n{structural.stdout or structural.stderr}"

    config_path = guardrails_config_path(cwd)
    configured = os.path.isfile(config_path) if config_path else False
    trusted = {}
    if configured:
        trusted, error = load_trusted_checks(cwd)
        if error:
            return checks, error
    selected = [name for name in ("primary", "integration") if name in trusted]
    try:
        from agentcam.redaction import redact_argv
    except Exception as exc:
        if selected:
            return checks, f"could not load command redaction: {exc}"
        redact_argv = lambda argv: argv
    for check_id in selected:
        started = time.monotonic()
        code, output = run_trusted_check(cwd, trusted[check_id], check_id)
        checks.append({
            "id": check_id,
            "argv": redact_argv(list(trusted[check_id]["argv"])),
            "exit_code": code,
            "duration_ms": round((time.monotonic() - started) * 1000),
            "state_fingerprint": fingerprint,
        })
        if code:
            return checks, f"trusted check {check_id} failed (exit {code}):\n{output[:1500]}"
    return checks, None


def _cached_review_checks(value, fingerprint):
    if not isinstance(value, list) or not value:
        return None
    for check in value:
        if (
            not isinstance(check, dict)
            or not isinstance(check.get("id"), str)
            or not isinstance(check.get("argv"), list)
            or not check["argv"]
            or any(not isinstance(item, str) or not item for item in check["argv"])
            or type(check.get("exit_code")) is not int
            or check["exit_code"] != 0
            or check.get("state_fingerprint") != fingerprint
        ):
            return None
    return value


def finish_delivery(cwd, data):
    baseline = load_baseline(cwd, data)
    if baseline is None:
        return {
            "decision": "block",
            "reason": (
                "turn baseline is unavailable — the hooks usually became "
                "active mid-turn; start a new conversation turn and retry"
            ),
        }
    if not baseline.get("agentcam_ready"):
        return {
            "decision": "block",
            "reason": (
                "Agentcam turn capture failed to initialize; run "
                "`guardrails doctor` to check the installation"
            ),
        }
    scope = read_delivery_scope(cwd)
    if not scope:
        return {
            "decision": "block",
            "reason": "Agent must declare the intended edit with `guardrails internal scope set`.",
        }
    changed = delivery_changed_files(cwd, baseline)
    if not changed:
        return {"decision": "ready", "changed": 0, "artifact": None}
    paths = scope.get("paths") or []
    outside = [
        item["path"] for item in changed
        if not any(glob_match(item["path"], pattern) for pattern in paths)
    ]
    if outside:
        return {
            "decision": "block",
            "reason": (
                "Out-of-scope changes: " + ", ".join(outside)
                + ". Revert them, or record the evidence with "
                "`guardrails internal scope add --path <path> --reason \"<evidence>\"`."
            ),
        }
    fingerprint = review_product_fingerprint(cwd, changed)
    risk, reasons = delivery_risk(changed)
    scanner_risk, scanner_reasons = agentcam_path_risk(changed)
    if scanner_risk is None:
        return {"decision": "block", "reason": "; ".join(scanner_reasons)}
    reasons = list(dict.fromkeys(reasons + scanner_reasons))
    if scanner_risk == "high":
        risk = "high"
    elif scanner_risk == "medium" and risk == "none-detected":
        risk = "medium"
    pending_state = _read_approval(cwd) if risk == "high" else {}
    checks = None
    if pending_state.get("product_fingerprint") == fingerprint:
        checks = _cached_review_checks(pending_state.get("checks"), fingerprint)
    if checks is None:
        checks, check_error = _run_review_checks(cwd, fingerprint)
        if check_error:
            return {"decision": "block", "reason": check_error}
    approval = None
    if risk == "high":
        pending = _pending_confirmation(
            cwd, fingerprint, reasons, baseline.get("agentcam_turn_id"), checks
        )
        if not pending.get("confirmed"):
            return {
                "decision": "block",
                "reason": "High-risk change needs your confirmation: " + "; ".join(reasons),
                "confirmation_phrase": pending["phrase"],
            }
        if pending.get("product_fingerprint") != fingerprint:
            return {
                "decision": "block",
                "reason": (
                    "high-risk confirmation is stale — the product changed "
                    "after it was confirmed; stopping again will issue a "
                    "fresh confirmation phrase"
                ),
            }
        approval = {
            "required": True,
            "confirmed": True,
            "product_fingerprint": fingerprint,
            "confirmation_id": pending["confirmation_id"],
        }
    finalized = baseline.get("finalized_agentcam")
    manifest = None
    if (
        isinstance(finalized, dict)
        and finalized.get("product_fingerprint") == fingerprint
        and isinstance(finalized.get("manifest"), dict)
    ):
        manifest = finalized["manifest"]
    else:
        if not _record_agentcam_checks(cwd, baseline, checks):
            return {"decision": "block", "reason": "could not record verification with Agentcam"}
        manifest = _finalize_agentcam(cwd, data, baseline)
        if manifest is None:
            return {
                "decision": "block",
                "reason": (
                    "the Agentcam hook-turn-end call failed; run "
                    "`guardrails doctor` to check the installation, then retry"
                ),
            }
        baseline["finalized_agentcam"] = {
            "product_fingerprint": fingerprint,
            "manifest": manifest,
        }
        state_path = baseline_path(cwd, data)
        try:
            _atomic_json(state_path, baseline)
        except (OSError, TypeError, ValueError) as exc:
            return {
                "decision": "block",
                "reason": f"could not preserve finalized Agentcam state: {exc}",
            }
    evidence = manifest.get("evidence") if isinstance(manifest.get("evidence"), dict) else {}
    if str(evidence.get("overall_risk") or "").upper() == "HIGH":
        risk = "high"
    capture_data = manifest.get("capture") if isinstance(manifest.get("capture"), dict) else {}
    review_first = next(
        (item["path"] for item in changed if any(
            segment in set(item["path"].lower().split("/"))
            for segment in HIGH_RISK_SEGMENTS
        )),
        changed[0]["path"],
    )
    recorded = any(item["id"] == "primary" for item in checks)
    # Read the version from the installed package: a hardcoded literal
    # would silently lie in the artifact after the next agentcam release.
    try:
        from agentcam import __version__ as agentcam_version
    except Exception:
        agentcam_version = "unknown"
    artifact = {
        "schema": 1,
        "generator": {
            "agentcam_version": agentcam_version,
            "runtime_revision": os.environ.get("GUARDRAILS_RUNTIME_REVISION", "development"),
        },
        "delivery": {
            "base_commit": scope.get("base_commit"),
            "product_fingerprint": fingerprint,
            "changed_files": changed,
            "outcomes": scope.get("outcomes") or [],
            "scope": paths,
            "scope_changes": scope.get("changes") or [],
            "review_first": review_first,
            "risk": risk,
        },
        "verification": {
            "level": "recorded" if recorded else "structural-only",
            "checks": checks,
        },
        "capture": {
            "terminal": (
                "captured" if capture_data.get("stdout") == "captured" else "unavailable"
            ),
            "coverage": (
                "full" if capture_data.get("output_risk_scan") == "enabled" else "partial"
            ),
        },
        "approval": approval,
    }
    try:
        _atomic_json(os.path.join(cwd, REVIEW_ARTIFACT), artifact)
    except (OSError, TypeError, ValueError) as exc:
        return {
            "decision": "block",
            "reason": f"could not write review artifact: {exc}",
        }
    return {
        "decision": "ready",
        "changed": len(changed),
        "checks": "primary passed" if recorded else "structural-only",
        "risk": risk,
        "review_first": review_first,
        "artifact": REVIEW_ARTIFACT,
    }


def product_paths(cwd, baseline=None):
    touched, new_files = changed_paths(cwd, baseline)
    return sorted(
        {
            path
            for path in touched + new_files
            if path != REVIEW_ARTIFACT
        }
    )


def stop(data):
    cwd = data.get("cwd") or os.getcwd()
    if not is_git(cwd):
        sys.exit(0)

    result = finish_delivery(cwd, data)
    if result.get("decision") == "block":
        reason = result["reason"]
        if result.get("confirmation_phrase"):
            reason += "\n\nReply exactly:\n" + result["confirmation_phrase"]
        print(json.dumps({"decision": "block", "reason": reason}, ensure_ascii=False))
        return
    clear_baselines(cwd, data)
    if result.get("artifact"):
        summary = (
            "Guardrails ready\n"
            f"Changed: {result['changed']} files\n"
            f"Checks: {result['checks']}\n"
            f"Risk: {result['risk']}\n"
            f"Review first: {result['review_first']}\n"
            f"Review artifact: {result['artifact']}"
        )
    else:
        summary = "Guardrails ready\nChanged: 0 files"
    print(json.dumps({"systemMessage": summary}, ensure_ascii=False))


def post_tool(data):
    if data.get("tool_name") != "Bash":
        return
    cwd = data.get("cwd") or os.getcwd()
    if not is_git(cwd):
        return
    baseline = load_baseline(cwd, data)
    scope = read_delivery_scope(cwd)
    globs = scope.get("paths") if isinstance(scope.get("paths"), list) else []
    products = _delivery_products(cwd, baseline)
    outside = [
        path for path in products
        if not any(glob_match(path, pattern) for pattern in globs)
    ] if globs else products
    reasons = []
    if products and not globs:
        reasons.append("Shell command produced product edits before the agent declared its intent.")
    if outside:
        reasons.append(
            "Shell command produced out-of-corridor product edits: "
            + ", ".join(outside[:10])
            + "."
        )
    if reasons:
        print(
            json.dumps(
                {
                    "decision": "block",
                    "reason": (
                        " ".join(reasons)
                        + " Revert them or update the Git-local scope with evidence. "
                        "The shell side effect already occurred; this hook cannot undo it."
                    ),
                }
            )
        )


def sync_pr_approval(cwd):
    artifact_path = os.path.join(cwd, REVIEW_ARTIFACT)
    try:
        with open(artifact_path, encoding="utf-8") as handle:
            artifact = json.load(handle)
    except (OSError, ValueError) as exc:
        raise ValueError(f"review artifact is unavailable: {exc}") from exc
    approval = artifact.get("approval") if isinstance(artifact, dict) else None
    delivery = artifact.get("delivery") if isinstance(artifact, dict) else None
    if not isinstance(approval, dict) or approval.get("confirmed") is not True:
        return {"status": "not-needed", "comments": []}
    if not isinstance(delivery, dict) or approval.get("product_fingerprint") != delivery.get("product_fingerprint"):
        raise ValueError("review artifact high-risk approval is stale")
    try:
        auth = subprocess.run(
            ["gh", "auth", "status"], cwd=cwd, capture_output=True, text=True,
            timeout=30,
        )
        if auth.returncode:
            raise ValueError("gh is not authenticated")
        view = subprocess.run(
            ["gh", "pr", "view", "--json", "number,headRefOid,comments"],
            cwd=cwd, capture_output=True, text=True, timeout=30,
        )
    except ValueError:
        raise
    except (OSError, subprocess.TimeoutExpired) as exc:
        raise ValueError(f"gh is unavailable: {exc}") from exc
    if view.returncode:
        raise ValueError("current branch has no accessible pull request")
    value = json.loads(view.stdout)
    head = current_head(cwd)
    if value.get("headRefOid") != head:
        raise ValueError("pull request head SHA does not match local HEAD")
    changed = delivery.get("changed_files") or []
    paths = [item.get("path") for item in changed if isinstance(item, dict)]
    labels = []
    if any(is_dependency_manifest(str(path)) for path in paths):
        labels.append("Guardrails-Dependency-Approval")
    if any(str(path).replace("\\", "/").startswith(".github/workflows/") for path in paths):
        labels.append("Guardrails-Workflow-Approval")
    existing = {
        str(comment.get("body") or "")
        for comment in value.get("comments", [])
        if isinstance(comment, dict)
    }
    posted = []
    for label in labels:
        body = f"{label}: {head}"
        if body in existing:
            continue
        result = subprocess.run(
            ["gh", "pr", "comment", str(value["number"]), "--body", body],
            cwd=cwd, capture_output=True, text=True, timeout=30,
        )
        if result.returncode:
            raise ValueError(f"could not post {label}")
        posted.append(body)
    return {"status": "synced", "comments": posted}


def cli_main(argv):
    parser = argparse.ArgumentParser(prog="guardrails-runtime")
    commands = parser.add_subparsers(dest="command", required=True)
    scope = commands.add_parser("scope")
    scope_commands = scope.add_subparsers(dest="scope_command", required=True)
    set_parser = scope_commands.add_parser("set")
    set_parser.add_argument("--repo", default=os.getcwd())
    set_parser.add_argument("--outcome", required=True)
    set_parser.add_argument("--path", action="append", required=True)
    add_parser = scope_commands.add_parser("add")
    add_parser.add_argument("--repo", default=os.getcwd())
    add_parser.add_argument("--path", action="append", required=True)
    add_parser.add_argument("--reason", required=True)
    approve = commands.add_parser("approve")
    approve.add_argument("nonce")
    approve.add_argument("--repo", default=os.getcwd())
    sync = commands.add_parser("pr-sync")
    sync.add_argument("--repo", default=os.getcwd())
    args = parser.parse_args(argv)
    if args.command == "scope":
        if args.scope_command == "set":
            set_delivery_scope(args.repo, args.outcome, args.path)
        else:
            add_delivery_scope(args.repo, args.path, args.reason)
        return 0
    if args.command == "approve":
        if not sys.stdin.isatty():
            raise ValueError("high-risk fallback approval requires an interactive terminal")
        pending = _read_approval(args.repo)
        if pending.get("nonce") != args.nonce:
            raise ValueError("approval nonce is missing or stale")
        phrase = f"確認高風險變更 {args.nonce}"
        typed = input(f"Type exactly `{phrase}`: ")
        if not accept_high_risk_prompt(args.repo, {"prompt": typed}):
            raise ValueError("confirmation phrase did not match")
        return 0
    result = sync_pr_approval(args.repo)
    print(json.dumps(result, ensure_ascii=False))
    return 0


def main():
    data = read_input()
    event = data.get("hook_event_name")
    if event == "UserPromptSubmit":
        if accept_high_risk_prompt(
            data.get("cwd") or os.getcwd(), data
        ):
            print(json.dumps({"systemMessage": "High-risk change confirmed; resume completion."}))
        else:
            record_baseline(data)
    elif event == "SessionStart":
        pass
    elif event == "PreToolUse":
        scope_gate(data)
    elif event == "PostToolUse":
        post_tool(data)
    elif event == "Stop":
        stop(data)
    elif event == "SessionEnd":
        cleanup_session(data.get("cwd") or os.getcwd(), data)
    sys.exit(0)


if __name__ == "__main__":
    if len(sys.argv) > 1:
        try:
            raise SystemExit(cli_main(sys.argv[1:]))
        except ValueError as exc:
            print(f"error: {exc}", file=sys.stderr)
            raise SystemExit(1)
    main()

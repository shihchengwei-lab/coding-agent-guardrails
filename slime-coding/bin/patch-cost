#!/usr/bin/env python3
"""Deterministic corridor and completion gates plus a factual cost report.

PreToolUse denies product edits without a valid corridor or outside its Paths.
Stop rechecks the persistent facts that must be true before completion:
configured typecheck/test commands pass, new dependencies are justified, all
product changes remain inside the corridor, and trivial work changes at most one
product file. PRUNED.md records rejected routes; it never waives a red gate.

Environment overrides:
  SLIME_TYPECHECK_CMD  optional typecheck command; if configured it must run and pass.
  SLIME_TEST_CMD       optional completion command, overriding Stop Condition Command.
  SLIME_TEST_TIMEOUT   seconds allowed for either command (default 600).
  SLIME_PUBSPEC        alternate pubspec path (default pubspec.yaml).
"""
import json
import os
import re
import shlex
import shutil
import subprocess
import sys

PUBSPEC = os.environ.get("SLIME_PUBSPEC", "pubspec.yaml")


def read_input():
    try:
        return json.load(sys.stdin)
    except Exception:
        return {}


def git(cwd, *args):
    # core.quotepath=false: git's default C-quoting turns non-ASCII paths into
    # "lib/caf\303\251.dart", which can never match a corridor glob and would
    # false-block — the one thing an L2 gate must not do.
    # encoding="utf-8": git emits UTF-8 path bytes; text=True alone decodes
    # with the locale codepage (e.g. cp936 on Chinese Windows), which
    # mangles non-ASCII paths and re-opens the same false-block.
    try:
        r = subprocess.run(
            ["git", "-c", "core.quotepath=false", *args],
            cwd=cwd,
            capture_output=True,
            text=True,
            encoding="utf-8",
            errors="replace",
            timeout=30,
        )
        return r.stdout if r.returncode == 0 else ""
    except Exception:
        return ""


def is_git(cwd):
    return bool(git(cwd, "rev-parse", "--is-inside-work-tree").strip())


# --------------------------------------------------------------------------
# L2 — PreToolUse corridor gate
# --------------------------------------------------------------------------
TEMPLATE_ID = "example-feature"
TEMPLATE_GLOBS = {"lib/feature/example/**", "test/feature/example/**"}
RIGOR_LEVELS = {"trivial", "normal", "high"}
RIGOR_REQUIRED_SECTIONS = {
    "trivial": ("outcome", "paths", "stop condition"),
    "normal": (
        "outcome",
        "paths",
        "evidence",
        "stop condition",
    ),
    "high": (
        "outcome",
        "paths",
        "evidence",
        "stop condition",
        "controls",
    ),
}


def corridor_id(cwd):
    path = os.path.join(cwd, ".slime", "corridor.md")
    try:
        with open(path, encoding="utf-8") as f:
            for line in f:
                m = re.match(r"#\s*Corridor:\s*(.+)", line.strip())
                if m:
                    return m.group(1).strip()
    except OSError:
        return None
    return None


def corridor_sections(cwd):
    """Parse ``##`` sections once for rigor validation and path matching.

    Values are stripped, non-empty source lines.  Section names are normalized
    to lower case because the Markdown is author-written, while the required
    shape remains deterministic enough for the L2 gate.
    """
    path = os.path.join(cwd, ".slime", "corridor.md")
    sections = {}
    current = None
    try:
        with open(path, encoding="utf-8") as f:
            for raw in f:
                stripped = raw.strip()
                heading = re.match(r"##\s+(.+?)\s*$", stripped)
                if heading:
                    current = " ".join(heading.group(1).lower().split())
                    sections.setdefault(current, [])
                    continue
                if current is not None and stripped:
                    sections[current].append(stripped)
    except OSError:
        return {}
    return sections


def corridor_rigor(cwd, sections=None):
    """Return explicit rigor, ``legacy``, or an invalid raw value."""
    sections = corridor_sections(cwd) if sections is None else sections
    if "rigor" not in sections:
        return "legacy"
    values = [
        line
        for line in sections.get("rigor", [])
        if not line.startswith("<!--")
    ]
    if not values:
        return "<empty>"
    if len(values) != 1:
        return "<multiple values>"
    return values[0].strip().lower()


def section_has_labeled_item(sections, section, label):
    pattern = re.compile(r"-\s*" + re.escape(label) + r"\s*\S", re.IGNORECASE)
    return any(pattern.match(line) for line in sections.get(section, []))


def corridor_problem(cwd):
    """Return a reason string if the corridor is missing/invalid, else None.

    Only unambiguous signals block: missing file, missing header, the template
    id, an empty Paths list, or paths still pointing at the template example.
    """
    path = os.path.join(cwd, ".slime", "corridor.md")
    if not os.path.exists(path):
        return ".slime/corridor.md is missing"
    cid = corridor_id(cwd)
    if not cid:
        return ".slime/corridor.md has no '# Corridor: <id>' header"
    if cid == TEMPLATE_ID:
        return ".slime/corridor.md is still the template (id 'example-feature')"
    globs = corridor_globs(cwd)
    if not globs:
        return ".slime/corridor.md has an empty '## Paths' list"
    if any(glob.strip() in {"*", "**", "**/*"} for glob in globs):
        return ".slime/corridor.md contains a match-all path instead of a corridor"
    if any(
        glob.startswith("/")
        or re.match(r"^[A-Za-z]:[/\\]", glob)
        or ".." in glob.replace("\\", "/").split("/")
        for glob in globs
    ):
        return ".slime/corridor.md Paths must stay inside the repository"
    if any(g in TEMPLATE_GLOBS for g in globs):
        return ".slime/corridor.md still lists the template example paths"

    sections = corridor_sections(cwd)
    rigor = corridor_rigor(cwd, sections)
    if rigor == "legacy":
        # Compatibility contract: an existing corridor with no explicit Rigor
        # keeps the pre-rigor section shape; match-all Paths are still invalid
        # because they erase the boundary rather than migrate its format.
        return None
    if rigor not in RIGOR_LEVELS:
        if rigor == "<empty>":
            return ".slime/corridor.md has an empty Rigor section"
        return (
            ".slime/corridor.md has unknown rigor "
            + repr(rigor)
            + "; expected trivial, normal, or high"
        )

    for required in RIGOR_REQUIRED_SECTIONS[rigor]:
        if not sections.get(required):
            display = " ".join(word.capitalize() for word in required.split())
            return f".slime/corridor.md rigor {rigor} requires a non-empty '## {display}' section"

    if rigor in {"normal", "high"}:
        if not section_has_labeled_item(sections, "evidence", "Supports:"):
            return ".slime/corridor.md Evidence requires a non-empty 'Supports:' item"
        if not section_has_labeled_item(sections, "evidence", "Would falsify:"):
            return ".slime/corridor.md Evidence requires a non-empty 'Would falsify:' item"

    if rigor == "high":
        for label in ("Failure mode:", "Rollback:", "Independent check:"):
            if not section_has_labeled_item(sections, "controls", label):
                return (
                    ".slime/corridor.md Controls requires a non-empty '"
                    + label
                    + "' item"
                )
    return None


# Repo-metadata files: not product code, no real frontier to compute, so the
# corridor concept doesn't apply. Matched by basename so a nested .gitignore
# (which git itself honours at any depth) is also exempt. README.md is
# deliberately NOT here — it describes product behaviour and is a real edit
# target. Keep the list conservative; widening it is a one-line change.
META_BASENAMES = {
    ".gitignore",
    ".gitattributes",
    ".editorconfig",
    "LICENSE",
    "LICENSE.md",
    "LICENSE.txt",
    "CHANGELOG.md",
}


def normalize_target(cwd, path):
    if not path:
        return None
    path = path.strip()
    if path in {"/dev/null", "NUL"}:
        return None
    fp = path
    absolute = fp if os.path.isabs(fp) else os.path.join(cwd, fp)
    try:
        return os.path.relpath(absolute, cwd).replace(os.sep, "/")
    except ValueError:
        return None


def target_paths(cwd, data):
    """Return every file target from Claude Edit/Write or Codex apply_patch."""
    tool_input = data.get("tool_input") or {}
    direct = tool_input.get("file_path") or tool_input.get("path")
    if direct:
        target = normalize_target(cwd, direct)
        return [target] if target else []

    if data.get("tool_name") != "apply_patch":
        return []
    command = tool_input.get("command")
    if not isinstance(command, str):
        return []
    targets = []
    pattern = re.compile(
        r"^\*\*\* (?:(?:Add|Update|Delete) File|Move to):\s*(.+?)\s*$",
        re.MULTILINE,
    )
    for match in pattern.finditer(command):
        target = normalize_target(cwd, match.group(1))
        if target and target not in targets:
            targets.append(target)
    return targets


def is_exempt_target(path):
    return path == ".slime" or path.startswith(".slime/") or (
        os.path.basename(path) in META_BASENAMES
    )


def deny_pretool(reason):
    print(
        json.dumps(
            {
                "hookSpecificOutput": {
                    "hookEventName": "PreToolUse",
                    "permissionDecision": "deny",
                    "permissionDecisionReason": "Slime Coding: " + reason,
                }
            }
        )
    )


def corridor_gate(data):
    cwd = data.get("cwd") or os.getcwd()
    targets = target_paths(cwd, data)
    if not targets:
        deny_pretool(
            "could not identify the edit target from the hook payload; "
            "refusing an unscoped write"
        )
        sys.exit(0)
    external = [
        path
        for path in targets
        if path == ".." or path.startswith("../")
    ]
    if external:
        deny_pretool(
            f"{', '.join(external)} is outside the repository and cannot be authorized by a corridor"
        )
        sys.exit(0)
    product_targets = [path for path in targets if not is_exempt_target(path)]
    # .slime artifacts must bootstrap the corridor itself; conservative repo
    # metadata is also outside the product boundary.
    if not product_targets:
        sys.exit(0)
    problem = corridor_problem(cwd)
    if problem:
        out = {
            "hookSpecificOutput": {
                "hookEventName": "PreToolUse",
                "permissionDecision": "deny",
                "permissionDecisionReason": (
                    "Slime Coding: " + problem + ". Define the Meeting Corridor "
                    "before editing — run /slime-corridor (or the slime-navigate "
                    "skill). No valid corridor = no evidence for where the "
                    "minimal change should land."
                ),
            }
        }
        print(json.dumps(out))
        sys.exit(0)
    globs = corridor_globs(cwd)
    outside = [
        target
        for target in product_targets
        if not any(glob_match(target, pattern) for pattern in globs)
    ]
    if outside:
        deny_pretool(
            f"{', '.join(outside)} is outside the corridor paths. Update the corridor with "
            "new evidence before editing, or keep the change inside its declared boundary."
        )
    sys.exit(0)


# --------------------------------------------------------------------------
# L2 — Stop: new-dependency gate
# --------------------------------------------------------------------------
def parse_deps(text):
    # Tolerant of real-world pubspec formatting: a trailing comment on the
    # dependencies: line and any consistent indent width (2 or 4 spaces) —
    # the old "exactly two spaces" match silently disabled the gate on
    # 4-space files. Direct deps are the entries at the block's first indent
    # level; deeper lines (sdk: flutter) are attributes, not deps.
    deps = set()
    in_block = False
    base_indent = None
    for line in text.splitlines():
        if re.match(r"^dependencies:\s*(#.*)?$", line):
            in_block = True
            base_indent = None
            continue
        if in_block:
            if re.match(r"^\S", line):  # next top-level key ends the block
                break
            m = re.match(r"^(\s+)([\w-]+):", line)
            if m:
                indent = len(m.group(1).expandtabs())
                if base_indent is None:
                    base_indent = indent
                if indent == base_indent:
                    deps.add(m.group(2))
    return deps


def pubspec_new_dependencies(cwd):
    head = git(cwd, "show", "HEAD:" + PUBSPEC)
    if not head:
        # No baseline at HEAD (fresh repo, or manifest not yet committed) — we
        # cannot tell new deps from existing ones, so degrade rather than
        # false-block. L2 gates must never fire on an ambiguous signal.
        return []
    try:
        with open(os.path.join(cwd, PUBSPEC), encoding="utf-8") as f:
            cur = f.read()
    except OSError:
        return []
    return sorted(parse_deps(cur) - parse_deps(head))


def requirement_name(spec):
    match = re.match(r"\s*([A-Za-z0-9_.-]+)", spec)
    return match.group(1).lower() if match else None


def dependency_names(path, text):
    name = os.path.basename(path)
    if name == "package.json":
        try:
            data = json.loads(text)
        except (TypeError, ValueError):
            return set()
        deps = set()
        for group in (
            "dependencies",
            "devDependencies",
            "peerDependencies",
            "optionalDependencies",
        ):
            values = data.get(group)
            if isinstance(values, dict):
                deps.update(str(key).lower() for key in values)
        return deps
    if name.startswith("requirements") and name.endswith(".txt"):
        deps = set()
        for line in text.splitlines():
            stripped = line.strip()
            if not stripped or stripped.startswith(("#", "-")):
                continue
            package = requirement_name(stripped)
            if package:
                deps.add(package)
        return deps
    if name in {"pyproject.toml", "Cargo.toml"}:
        try:
            import tomllib

            data = tomllib.loads(text)
        except (ImportError, ValueError):
            return set()
        if name == "Cargo.toml":
            deps = set()
            for group in ("dependencies", "dev-dependencies", "build-dependencies"):
                values = data.get(group)
                if isinstance(values, dict):
                    deps.update(str(key).lower() for key in values)
            return deps
        deps = set()
        project = data.get("project")
        if isinstance(project, dict):
            for spec in project.get("dependencies", []):
                package = requirement_name(str(spec))
                if package:
                    deps.add(package)
            optional = project.get("optional-dependencies")
            if isinstance(optional, dict):
                for specs in optional.values():
                    if isinstance(specs, list):
                        for spec in specs:
                            package = requirement_name(str(spec))
                            if package:
                                deps.add(package)
        poetry = data.get("tool", {}).get("poetry", {})
        if isinstance(poetry, dict):
            for group in ("dependencies", "dev-dependencies"):
                values = poetry.get(group)
                if isinstance(values, dict):
                    deps.update(str(key).lower() for key in values if key != "python")
        return deps
    if name == "go.mod":
        deps = set()
        in_block = False
        for line in text.splitlines():
            stripped = line.strip()
            if stripped == "require (":
                in_block = True
                continue
            if in_block and stripped == ")":
                in_block = False
                continue
            if stripped.startswith("require "):
                parts = stripped.split()
                if len(parts) >= 2:
                    deps.add(parts[1])
            elif in_block and stripped and not stripped.startswith("//"):
                deps.add(stripped.split()[0])
        return deps
    return set()


def dependency_manifest_paths(cwd):
    touched, new_files = changed_paths(cwd)
    supported = {"package.json", "pyproject.toml", "Cargo.toml", "go.mod"}
    return sorted(
        {
            path
            for path in touched + new_files
            if os.path.basename(path) in supported
            or (
                os.path.basename(path).startswith("requirements")
                and path.endswith(".txt")
            )
        }
    )


def new_dependencies(cwd):
    added = [f"{PUBSPEC}: {name}" for name in pubspec_new_dependencies(cwd)]
    for path in dependency_manifest_paths(cwd):
        try:
            with open(os.path.join(cwd, path), encoding="utf-8") as f:
                current = f.read()
        except OSError:
            continue
        baseline = git(cwd, "show", "HEAD:" + path)
        for package in sorted(
            dependency_names(path, current) - dependency_names(path, baseline)
        ):
            added.append(f"{path}: {package}")
    return sorted(added)


def justified_dependencies(cwd):
    justified = set()
    for line in corridor_sections(cwd).get("evidence", []):
        match = re.match(r"-\s*Dependency:\s*(\S+)", line, re.IGNORECASE)
        if match:
            justified.add(match.group(1).lower())
    return justified


def dependency_package(record):
    return record.rsplit(": ", 1)[-1].lower()


def stop_command(cwd):
    for line in corridor_sections(cwd).get("stop condition", []):
        match = re.match(r"-\s*Command:\s*(.+)", line, re.IGNORECASE)
        if match:
            return match.group(1).strip().strip("`")
    return None


def run_check(cwd):
    cmd = os.environ.get("SLIME_TEST_CMD") or stop_command(cwd)
    if not cmd:
        return None
    try:
        timeout = int(os.environ.get("SLIME_TEST_TIMEOUT", "600"))
        r = subprocess.run(
            cmd, cwd=cwd, shell=True, capture_output=True, text=True, timeout=timeout
        )
        return r.returncode, (r.stdout or r.stderr or "")
    except subprocess.TimeoutExpired:
        return 124, f"check timed out after {timeout} seconds: {cmd}"
    except Exception as exc:
        return 126, f"check could not run: {exc}"


def run_typecheck(cwd):
    """Run the configured typecheck; configured means it must run and pass."""
    cmd = os.environ.get("SLIME_TYPECHECK_CMD")
    if not cmd:
        return None
    # Resolve the first token so a missing executable produces the same clear
    # failure on POSIX and Windows instead of depending on shell exit codes.
    try:
        parts = shlex.split(cmd, posix=(os.name != "nt"))
    except ValueError:
        parts = cmd.split()
    prog = parts[0] if parts else ""
    if prog and not shutil.which(prog):
        return 127, f"typecheck could not run: command not found: {prog}"
    try:
        timeout = int(os.environ.get("SLIME_TEST_TIMEOUT", "600"))
        r = subprocess.run(
            cmd, cwd=cwd, shell=True, capture_output=True, text=True, timeout=timeout
        )
        return r.returncode, (r.stdout or r.stderr or "")
    except subprocess.TimeoutExpired:
        return 124, f"typecheck timed out after {timeout} seconds: {cmd}"
    except Exception as exc:
        return 126, f"typecheck could not run: {exc}"


# --------------------------------------------------------------------------
# L3 — Stop: cost report
# --------------------------------------------------------------------------
def corridor_globs(cwd):
    globs = []
    sections = corridor_sections(cwd)
    if "rigor" not in sections:
        # This is the pre-rigor parser kept verbatim for compatibility.
        path = os.path.join(cwd, ".slime", "corridor.md")
        try:
            with open(path, encoding="utf-8") as f:
                in_paths = False
                for raw in f:
                    line = raw.strip()
                    if line.lower().startswith("## paths"):
                        in_paths = True
                        continue
                    if in_paths:
                        if line.startswith("##"):
                            break
                        match = re.match(r"-\s+(.+)", line)
                        if match:
                            globs.append(match.group(1).strip())
        except OSError:
            return []
        return globs

    for line in sections.get("paths", []):
        match = re.match(r"-\s+(.+)", line)
        if match:
            globs.append(match.group(1).strip())
    return globs


def changed_paths(cwd):
    touched = [n for n in git(cwd, "diff", "HEAD", "--name-only").splitlines() if n]
    new_files = [
        u
        for u in git(cwd, "ls-files", "--others", "--exclude-standard").splitlines()
        if u
    ]
    return touched, new_files


def glob_to_regex(pattern):
    """git-style glob -> regex: * and ? never cross /, **/ spans zero+ dirs.

    fnmatch's * crosses /, which made a corridor of lib/*.dart silently
    admit lib/vendor/deep.dart.
    """
    parts = []
    i = 0
    n = len(pattern)
    while i < n:
        ch = pattern[i]
        if ch == "*":
            if pattern.startswith("**/", i):
                parts.append("(?:[^/]+/)*")
                i += 3
            elif pattern.startswith("**", i):
                parts.append(".*")
                i += 2
            else:
                parts.append("[^/]*")
                i += 1
        elif ch == "?":
            parts.append("[^/]")
            i += 1
        else:
            parts.append(re.escape(ch))
            i += 1
    return re.compile("".join(parts) + r"\Z")


def glob_match(path, pattern):
    if pattern.endswith("/**"):
        prefix = pattern[:-3].rstrip("/")
        return path == prefix or path.startswith(prefix + "/")
    return glob_to_regex(pattern).match(path) is not None


def out_of_corridor_files(cwd):
    globs = corridor_globs(cwd)
    if not globs:
        return []
    touched, new_files = changed_paths(cwd)
    out_corr = []
    for n in touched + new_files:
        # .slime/ artifacts aren't scope creep: corridor edits are tracked
        # separately (corridor changed), and PRUNED.md updates are required.
        if n.startswith(".slime/"):
            continue
        # Repo metadata is not product code, so the default strict corridor gate
        # should not turn harmless config hygiene into a hard stop.
        if os.path.basename(n) in META_BASENAMES:
            continue
        if not any(glob_match(n, g) for g in globs):
            out_corr.append(n)
    return out_corr


def l3_report(cwd):
    touched, new_files = changed_paths(cwd)
    globs = corridor_globs(cwd)
    out_corr = out_of_corridor_files(cwd)
    rigor = corridor_rigor(cwd)
    lines = [
        "Slime Coding — cost report:",
        f"  corridor rigor: {rigor}",
        f"  touched files: {len(touched)}",
        f"  new files: {len(new_files)}",
    ]
    if globs:
        suffix = f" -> {', '.join(out_corr[:10])}" if out_corr else ""
        lines.append(f"  out-of-corridor files: {len(out_corr)}{suffix}")
    else:
        lines.append("  out-of-corridor: (no '## Paths' defined in corridor.md)")
    # The corridor gate always lets .slime/ through (to avoid a bootstrap
    # deadlock), so widening the corridor mid-task is possible. That can be
    # legitimate new evidence, so we don't block — but surface it for the user.
    corridor_changed = bool(
        git(cwd, "status", "--porcelain", "--", ".slime/corridor.md").strip()
    )
    lines.append(f"  corridor changed this session: {'yes' if corridor_changed else 'no'}")
    return "\n".join(lines)


def product_paths(cwd):
    touched, new_files = changed_paths(cwd)
    return sorted(
        {
            path
            for path in touched + new_files
            if not path.startswith(".slime/")
            and os.path.basename(path) not in META_BASENAMES
        }
    )


def stop_blocks(cwd):
    blocks = []

    typecheck = run_typecheck(cwd)
    if typecheck is not None and typecheck[0] != 0:
        blocks.append(
            "Typecheck failed or could not run (exit "
            + str(typecheck[0])
            + "). Fix the command or code before finishing; unresolved names "
            "may be hallucinated attachment points.\n\n"
            + typecheck[1][:1500]
        )

    allowed_dependencies = justified_dependencies(cwd)
    dependencies = [
        record
        for record in new_dependencies(cwd)
        if dependency_package(record) not in allowed_dependencies
    ]
    if dependencies:
        blocks.append(
            "New dependency added without corridor evidence: "
            + ", ".join(dependencies)
            + ". Remove it or add '- Dependency: <package> — <reason>' to "
            ".slime/corridor.md Evidence."
        )

    check = run_check(cwd)
    if check is not None and check[0] != 0:
        blocks.append(
            "Configured Stop check failed or could not run (exit "
            + str(check[0])
            + "). Make it pass before finishing. PRUNED.md records rejected "
            "routes; it never waives a failing check.\n\n"
            + check[1][:1500]
        )

    outside = out_of_corridor_files(cwd)
    if outside:
        blocks.append(
            "Out-of-corridor product edits detected: "
            + ", ".join(outside[:10])
            + ". Move the change inside Paths or update the corridor with the "
            "new evidence before editing."
        )

    products = product_paths(cwd)
    problem = corridor_problem(cwd)
    if problem and products:
        blocks.append(
            "Product code changed but "
            + problem
            + ". Restore or complete .slime/corridor.md before finishing: "
            + ", ".join(products[:10])
        )

    if corridor_rigor(cwd) == "trivial" and len(products) > 1:
        blocks.append(
            "A trivial corridor may change one product file; found "
            + str(len(products))
            + ": "
            + ", ".join(products[:10])
            + ". Use normal rigor or narrow the change."
        )

    return blocks


def stop(data):
    cwd = data.get("cwd") or os.getcwd()
    if not is_git(cwd):
        sys.exit(0)

    # Re-run every gate on every Stop. Retrying Stop does not turn red evidence
    # into completion.
    blocks = stop_blocks(cwd)
    report = l3_report(cwd)
    if blocks:
        print(json.dumps({"decision": "block", "reason": "\n\n".join(blocks) + "\n\n" + report}))
        sys.exit(0)
    print(json.dumps({"systemMessage": report}))
    sys.exit(0)


def main():
    data = read_input()
    event = data.get("hook_event_name")
    if event == "PreToolUse":
        corridor_gate(data)
    elif event == "Stop":
        stop(data)
    sys.exit(0)


if __name__ == "__main__":
    main()

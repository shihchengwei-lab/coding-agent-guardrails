#!/usr/bin/env python3
"""L2 deterministic gates + L3 fuzzy measurement.

One binary, registered on two events; it dispatches on hook_event_name.

  PreToolUse (Edit|Write)  -> L2 corridor gate.
                              Deny edits when .slime/corridor.md is absent —
                              no corridor means no evidence for where to cut.

  Stop                     -> L2 tool-fact gates (block) + L3 cost report.
                              * typecheck gate: SLIME_TYPECHECK_CMD (e.g.
                                `dart analyze`) is red at Stop -> block. It is
                                the contact sensor for hallucinated attachment
                                points; no log-and-leave escape (unresolved
                                code is broken, not abandoned). Opt-in; degrades
                                if unset.
                              * new-dependency gate: pubspec.yaml gained a
                                dependency this session -> block, demand a
                                keep/remove decision.
                              * failing-check-at-stop gate: SLIME_TEST_CMD is
                                red at Stop and nothing was recorded in
                                PRUNED.md -> block. The teeth are on the
                                unambiguous fact "the check is failing as you
                                finish"; recording the abandoned design in
                                PRUNED.md is just the acknowledgement that lets
                                you stop on red (the other way out is to make
                                the check pass). It is NOT a check that you
                                "pruned" anything — abandoning a design is not a
                                git fact.
                              L3 metrics (touched/new files, public-API adds)
                              are reported. Out-of-corridor product-code edits
                              block by default because they are direct evidence
                              of semantic displacement.

L2 gates fire only on unambiguous git facts (zero inference), so a false block
that would train users to disable the hook cannot happen here. L3 carries the
fuzzy signals and reports by default; the corridor boundary is the exception
because the file path either matches the committed corridor or it doesn't.

Tunables (env):
  SLIME_TEST_CMD       shell command run as the check for the prune gate.
                       If unset, the prune-logging gate degrades (skipped).
  SLIME_TEST_TIMEOUT   seconds before the check is abandoned (default 600).
  SLIME_PUBSPEC        path to the dependency manifest (default pubspec.yaml).
  SLIME_STRICT_CORRIDOR
                       Default: strict. Set 0/false/no/off to make
                       out-of-corridor product-code edits report-only.
"""
import json
import os
import re
import shlex
import shutil
import subprocess
import sys

PUBSPEC = os.environ.get("SLIME_PUBSPEC", "pubspec.yaml")


def env_falsey(name):
    return os.environ.get(name, "").strip().lower() in {"0", "false", "no", "off"}


def strict_corridor_enabled():
    return not env_falsey("SLIME_STRICT_CORRIDOR")


def read_input():
    try:
        return json.load(sys.stdin)
    except Exception:
        return {}


def git(cwd, *args):
    # core.quotepath=false: git's default C-quoting turns non-ASCII paths into
    # "lib/caf\303\251.dart", which can never match a corridor glob and would
    # false-block — the one thing an L2 gate must not do.
    # encoding="utf-8": git emits UTF-8 path bytes; text=True alone decodes
    # with the locale codepage (e.g. cp936 on Chinese Windows), which
    # mangles non-ASCII paths and re-opens the same false-block.
    try:
        r = subprocess.run(
            ["git", "-c", "core.quotepath=false", *args],
            cwd=cwd,
            capture_output=True,
            text=True,
            encoding="utf-8",
            errors="replace",
            timeout=30,
        )
        return r.stdout if r.returncode == 0 else ""
    except Exception:
        return ""


def is_git(cwd):
    return bool(git(cwd, "rev-parse", "--is-inside-work-tree").strip())


# --------------------------------------------------------------------------
# L2 — PreToolUse corridor gate
# --------------------------------------------------------------------------
TEMPLATE_ID = "example-feature"
TEMPLATE_GLOBS = {"lib/feature/example/**", "test/feature/example/**"}
RIGOR_LEVELS = {"trivial", "normal", "high"}
RIGOR_REQUIRED_SECTIONS = {
    "trivial": ("scope", "paths", "stop condition"),
    "normal": (
        "scope",
        "semantic delta",
        "non-goals",
        "paths",
        "goal frontier",
        "start frontier",
        "evidence",
        "stop condition",
    ),
    "high": (
        "scope",
        "semantic delta",
        "non-goals",
        "paths",
        "goal frontier",
        "start frontier",
        "evidence",
        "stop condition",
        "high-risk controls",
    ),
}


def corridor_id(cwd):
    path = os.path.join(cwd, ".slime", "corridor.md")
    try:
        with open(path, encoding="utf-8") as f:
            for line in f:
                m = re.match(r"#\s*Corridor:\s*(.+)", line.strip())
                if m:
                    return m.group(1).strip()
    except OSError:
        return None
    return None


def corridor_sections(cwd):
    """Parse ``##`` sections once for rigor validation and path matching.

    Values are stripped, non-empty source lines.  Section names are normalized
    to lower case because the Markdown is author-written, while the required
    shape remains deterministic enough for the L2 gate.
    """
    path = os.path.join(cwd, ".slime", "corridor.md")
    sections = {}
    current = None
    try:
        with open(path, encoding="utf-8") as f:
            for raw in f:
                stripped = raw.strip()
                heading = re.match(r"##\s+(.+?)\s*$", stripped)
                if heading:
                    current = " ".join(heading.group(1).lower().split())
                    sections.setdefault(current, [])
                    continue
                if current is not None and stripped:
                    sections[current].append(stripped)
    except OSError:
        return {}
    return sections


def corridor_rigor(cwd, sections=None):
    """Return explicit rigor, ``legacy``, or an invalid raw value."""
    sections = corridor_sections(cwd) if sections is None else sections
    if "rigor" not in sections:
        return "legacy"
    values = [
        line
        for line in sections.get("rigor", [])
        if not line.startswith("<!--")
    ]
    if not values:
        return "<empty>"
    if len(values) != 1:
        return "<multiple values>"
    return values[0].strip().lower()


def section_has_labeled_item(sections, section, label):
    pattern = re.compile(r"-\s*" + re.escape(label) + r"\s*\S", re.IGNORECASE)
    return any(pattern.match(line) for line in sections.get(section, []))


def corridor_problem(cwd):
    """Return a reason string if the corridor is missing/invalid, else None.

    Only unambiguous signals block: missing file, missing header, the template
    id, an empty Paths list, or paths still pointing at the template example.
    """
    path = os.path.join(cwd, ".slime", "corridor.md")
    if not os.path.exists(path):
        return ".slime/corridor.md is missing"
    cid = corridor_id(cwd)
    if not cid:
        return ".slime/corridor.md has no '# Corridor: <id>' header"
    if cid == TEMPLATE_ID:
        return ".slime/corridor.md is still the template (id 'example-feature')"
    globs = corridor_globs(cwd)
    if not globs:
        return ".slime/corridor.md has an empty '## Paths' list"
    if any(g in TEMPLATE_GLOBS for g in globs):
        return ".slime/corridor.md still lists the template example paths"

    sections = corridor_sections(cwd)
    rigor = corridor_rigor(cwd, sections)
    if rigor == "legacy":
        # Compatibility contract: an existing corridor with no explicit Rigor
        # keeps the pre-rigor validation shape (header + non-template Paths).
        return None
    if rigor not in RIGOR_LEVELS:
        if rigor == "<empty>":
            return ".slime/corridor.md has an empty Rigor section"
        return (
            ".slime/corridor.md has unknown rigor "
            + repr(rigor)
            + "; expected trivial, normal, or high"
        )

    for required in RIGOR_REQUIRED_SECTIONS[rigor]:
        if not sections.get(required):
            display = " ".join(word.capitalize() for word in required.split())
            return f".slime/corridor.md rigor {rigor} requires a non-empty '## {display}' section"

    if rigor in {"normal", "high"}:
        if not section_has_labeled_item(sections, "evidence", "Supports:"):
            return ".slime/corridor.md Evidence requires a non-empty 'Supports:' item"
        if not section_has_labeled_item(sections, "evidence", "Would falsify:"):
            return ".slime/corridor.md Evidence requires a non-empty 'Would falsify:' item"

    if rigor == "high":
        for label in ("Failure mode:", "Rollback:", "Independent check:"):
            if not section_has_labeled_item(
                sections, "high-risk controls", label
            ):
                return (
                    ".slime/corridor.md High-risk Controls requires a non-empty '"
                    + label
                    + "' item"
                )
    return None


# Repo-metadata files: not product code, no real frontier to compute, so the
# corridor concept doesn't apply. Matched by basename so a nested .gitignore
# (which git itself honours at any depth) is also exempt. README.md is
# deliberately NOT here — it describes product behaviour and is a real edit
# target. Keep the list conservative; widening it is a one-line change.
META_BASENAMES = {
    ".gitignore",
    ".gitattributes",
    ".editorconfig",
    "LICENSE",
    "LICENSE.md",
    "LICENSE.txt",
    "CHANGELOG.md",
}


def under_slime(cwd, tool_input):
    """True when the edit targets a .slime/ artifact (always allowed, so the
    corridor and pruned log can be bootstrapped without a corridor)."""
    fp = (tool_input or {}).get("file_path") or (tool_input or {}).get("path") or ""
    if not fp:
        return False
    abs_fp = fp if os.path.isabs(fp) else os.path.join(cwd, fp)
    try:
        rel = os.path.relpath(abs_fp, cwd)
    except ValueError:
        return False
    return rel.split(os.sep)[0] == ".slime"


def is_meta_file(tool_input):
    """True when the edit target's basename is in META_BASENAMES, so nested
    .gitignore / .gitattributes (which git honours at any depth) also pass."""
    fp = (tool_input or {}).get("file_path") or (tool_input or {}).get("path") or ""
    return os.path.basename(fp) in META_BASENAMES if fp else False


def corridor_gate(data):
    cwd = data.get("cwd") or os.getcwd()
    tool_input = data.get("tool_input")
    # Bootstrap exemption: writing .slime/ artifacts (corridor.md, PRUNED.md)
    # never needs a corridor, otherwise creating one would deadlock.
    if under_slime(cwd, tool_input):
        sys.exit(0)
    # Repo-metadata exemption: .gitignore et al. are not product code, so the
    # corridor concept has no real frontier against them — requiring a corridor
    # is pure friction.
    if is_meta_file(tool_input):
        sys.exit(0)
    problem = corridor_problem(cwd)
    if problem:
        out = {
            "hookSpecificOutput": {
                "hookEventName": "PreToolUse",
                "permissionDecision": "deny",
                "permissionDecisionReason": (
                    "Slime Coding: " + problem + ". Define the Meeting Corridor "
                    "before editing — run /slime-corridor (or the slime-navigate "
                    "skill). No valid corridor = no evidence for where the "
                    "minimal change should land."
                ),
            }
        }
        print(json.dumps(out))
    sys.exit(0)


# --------------------------------------------------------------------------
# L2 — Stop: new-dependency gate
# --------------------------------------------------------------------------
def parse_deps(text):
    # Tolerant of real-world pubspec formatting: a trailing comment on the
    # dependencies: line and any consistent indent width (2 or 4 spaces) —
    # the old "exactly two spaces" match silently disabled the gate on
    # 4-space files. Direct deps are the entries at the block's first indent
    # level; deeper lines (sdk: flutter) are attributes, not deps.
    deps = set()
    in_block = False
    base_indent = None
    for line in text.splitlines():
        if re.match(r"^dependencies:\s*(#.*)?$", line):
            in_block = True
            base_indent = None
            continue
        if in_block:
            if re.match(r"^\S", line):  # next top-level key ends the block
                break
            m = re.match(r"^(\s+)([\w-]+):", line)
            if m:
                indent = len(m.group(1).expandtabs())
                if base_indent is None:
                    base_indent = indent
                if indent == base_indent:
                    deps.add(m.group(2))
    return deps


def new_dependencies(cwd):
    head = git(cwd, "show", "HEAD:" + PUBSPEC)
    if not head:
        # No baseline at HEAD (fresh repo, or manifest not yet committed) — we
        # cannot tell new deps from existing ones, so degrade rather than
        # false-block. L2 gates must never fire on an ambiguous signal.
        return []
    try:
        with open(os.path.join(cwd, PUBSPEC), encoding="utf-8") as f:
            cur = f.read()
    except OSError:
        return []
    return sorted(parse_deps(cur) - parse_deps(head))


# --------------------------------------------------------------------------
# L2 — Stop: prune-logging gate
# --------------------------------------------------------------------------
def pruned_touched(cwd):
    status = git(cwd, "status", "--porcelain", "--", ".slime/PRUNED.md").strip()
    if not status:
        return False
    if not status.startswith("??"):
        # Tracked with uncommitted changes — an unambiguous git fact that the
        # log was written this session.
        return True
    # Untracked. install.sh seeds PRUNED.md as an untracked template, and
    # counting "??" as touched made this gate permanently dead out of the box.
    # An untracked log only counts once it carries a record for a real
    # corridor (the seeded template ships one example-feature record).
    try:
        with open(os.path.join(cwd, ".slime", "PRUNED.md"), encoding="utf-8") as f:
            text = f.read()
    except OSError:
        return False
    for m in re.finditer(r"^##\s*\[.*?\]\s*corridor:(\S+)", text, re.MULTILINE):
        if m.group(1) != TEMPLATE_ID:
            return True
    return False


def run_check(cwd):
    cmd = os.environ.get("SLIME_TEST_CMD")
    if not cmd:
        return None  # gate degrades when no runnable check exists
    try:
        timeout = int(os.environ.get("SLIME_TEST_TIMEOUT", "600"))
        r = subprocess.run(
            cmd, cwd=cwd, shell=True, capture_output=True, text=True, timeout=timeout
        )
        return r.returncode
    except Exception:
        return None


def run_typecheck(cwd):
    """Run SLIME_TYPECHECK_CMD (e.g. `dart analyze`) as a contact sensor for the
    patch. Returns (returncode, output) when the command actually ran, or None
    when the gate must degrade (unset / missing command / timeout / error) — a
    typechecker is the only thing that can tell a real attachment point from a
    hallucinated one, but L2 must never false-block on an ambiguous signal."""
    cmd = os.environ.get("SLIME_TYPECHECK_CMD")
    if not cmd:
        return None
    # "command not found -> degrade" cross-platform. POSIX shells report exit
    # 127, but Windows cmd.exe returns 1 — indistinguishable from a real
    # typecheck failure — so the exit code alone can't carry this signal. Resolve
    # the program (first token) on PATH first; if it isn't installed the command
    # is misconfigured, not evidence of a hallucinated reference, so degrade. L2
    # must never false-block on an ambiguous signal.
    try:
        parts = shlex.split(cmd, posix=(os.name != "nt"))
    except ValueError:
        parts = cmd.split()
    prog = parts[0] if parts else ""
    if prog and not shutil.which(prog):
        return None
    try:
        timeout = int(os.environ.get("SLIME_TEST_TIMEOUT", "600"))
        r = subprocess.run(
            cmd, cwd=cwd, shell=True, capture_output=True, text=True, timeout=timeout
        )
        if r.returncode == 127:
            # POSIX "command not found" — same rationale as the PATH check above.
            return None
        return r.returncode, (r.stdout or r.stderr or "")
    except Exception:
        return None


# --------------------------------------------------------------------------
# L3 — Stop: cost report
# --------------------------------------------------------------------------
def corridor_globs(cwd):
    globs = []
    sections = corridor_sections(cwd)
    if "rigor" not in sections:
        # This is the pre-rigor parser kept verbatim for compatibility.
        path = os.path.join(cwd, ".slime", "corridor.md")
        try:
            with open(path, encoding="utf-8") as f:
                in_paths = False
                for raw in f:
                    line = raw.strip()
                    if line.lower().startswith("## paths"):
                        in_paths = True
                        continue
                    if in_paths:
                        if line.startswith("##"):
                            break
                        match = re.match(r"-\s+(.+)", line)
                        if match:
                            globs.append(match.group(1).strip())
        except OSError:
            return []
        return globs

    for line in sections.get("paths", []):
        match = re.match(r"-\s+(.+)", line)
        if match:
            globs.append(match.group(1).strip())
    return globs


def changed_paths(cwd):
    touched = [n for n in git(cwd, "diff", "HEAD", "--name-only").splitlines() if n]
    new_files = [
        u
        for u in git(cwd, "ls-files", "--others", "--exclude-standard").splitlines()
        if u
    ]
    return touched, new_files


def glob_to_regex(pattern):
    """git-style glob -> regex: * and ? never cross /, **/ spans zero+ dirs.

    fnmatch's * crosses /, which made a corridor of lib/*.dart silently
    admit lib/vendor/deep.dart. Duplicated in commit-evidence (both bin
    scripts are deliberately self-contained, like parse_deps).
    """
    parts = []
    i = 0
    n = len(pattern)
    while i < n:
        ch = pattern[i]
        if ch == "*":
            if pattern.startswith("**/", i):
                parts.append("(?:[^/]+/)*")
                i += 3
            elif pattern.startswith("**", i):
                parts.append(".*")
                i += 2
            else:
                parts.append("[^/]*")
                i += 1
        elif ch == "?":
            parts.append("[^/]")
            i += 1
        else:
            parts.append(re.escape(ch))
            i += 1
    return re.compile("".join(parts) + r"\Z")


def glob_match(path, pattern):
    if pattern in ("*", "**", "**/*"):
        return True
    if pattern.endswith("/**"):
        prefix = pattern[:-3].rstrip("/")
        return path == prefix or path.startswith(prefix + "/")
    return glob_to_regex(pattern).match(path) is not None


def out_of_corridor_files(cwd):
    globs = corridor_globs(cwd)
    if not globs:
        return []
    touched, new_files = changed_paths(cwd)
    out_corr = []
    for n in touched + new_files:
        # .slime/ artifacts aren't scope creep: corridor edits are tracked
        # separately (corridor changed), and PRUNED.md updates are required.
        if n.startswith(".slime/"):
            continue
        # Repo metadata is not product code, so the default strict corridor gate
        # should not turn harmless config hygiene into a hard stop.
        if os.path.basename(n) in META_BASENAMES:
            continue
        if not any(glob_match(n, g) for g in globs):
            out_corr.append(n)
    return out_corr


def l3_report(cwd):
    touched, new_files = changed_paths(cwd)
    diff = git(cwd, "diff", "HEAD")
    api = 0
    for line in diff.splitlines():
        if line.startswith("+") and not line.startswith("+++"):
            c = line[1:].lstrip()
            if re.match(r"(export\s|class\s|enum\s|mixin\s|typedef\s|extension\s)", c):
                api += 1

    globs = corridor_globs(cwd)
    out_corr = out_of_corridor_files(cwd)
    rigor = corridor_rigor(cwd)
    product = sorted(
        {
            path
            for path in touched + new_files
            if not path.startswith(".slime/")
            and os.path.basename(path) not in META_BASENAMES
        }
    )
    dependency_signal = bool(new_dependencies(cwd))

    lines = [
        "Slime Coding — cost report:",
        f"  corridor rigor: {rigor}",
        f"  touched files: {len(touched)}",
        f"  new files: {len(new_files)}",
        f"  public-API additions (Dart export/class/enum/mixin/typedef): {api}",
    ]
    if globs:
        suffix = f" -> {', '.join(out_corr[:10])}" if out_corr else ""
        lines.append(f"  out-of-corridor files: {len(out_corr)}{suffix}")
    else:
        lines.append("  out-of-corridor: (no '## Paths' defined in corridor.md)")
    # The corridor gate always lets .slime/ through (to avoid a bootstrap
    # deadlock), so widening the corridor mid-task is possible. That can be
    # legitimate new evidence, so we don't block — but surface it for the user.
    corridor_changed = bool(
        git(cwd, "status", "--porcelain", "--", ".slime/corridor.md").strip()
    )
    lines.append(f"  corridor changed this session: {'yes' if corridor_changed else 'no'}")
    mismatch_reasons = []
    if rigor == "trivial":
        if len(product) > 1:
            mismatch_reasons.append(f"{len(product)} product files changed")
        if api:
            mismatch_reasons.append(f"{api} public-API addition(s) detected")
        if dependency_signal:
            mismatch_reasons.append("a dependency change was detected")
        if mismatch_reasons:
            lines.append(
                "  rigor mismatch: trivial evidence suggests consider normal/high ("
                + "; ".join(mismatch_reasons)
                + ")"
            )
    elif rigor == "normal":
        if len(product) > 12:
            mismatch_reasons.append(f"{len(product)} product files changed")
        if api:
            mismatch_reasons.append(f"{api} public-API addition(s) detected")
        if dependency_signal:
            mismatch_reasons.append("a dependency change was detected")
        if mismatch_reasons:
            lines.append(
                "  rigor mismatch: normal evidence suggests consider high ("
                + "; ".join(mismatch_reasons)
                + ")"
            )
    return "\n".join(lines)


def stop(data):
    cwd = data.get("cwd") or os.getcwd()
    if not is_git(cwd):
        sys.exit(0)

    blocks = []
    # Guard against infinite Stop loops: only block on the first pass.
    if not data.get("stop_hook_active"):
        # Typecheck (contact sensor) goes first: a reference that doesn't
        # resolve means the code never compiled, which is more fundamental than
        # a dependency or a red test. Unlike the failing-check gate below, this
        # has NO log-and-leave escape — an unresolved reference is broken code,
        # not an abandoned-but-acknowledged design, so the only way out is to
        # fix the reference (or scope it as new work in the corridor).
        tc = run_typecheck(cwd)
        if tc is not None and tc[0] != 0:
            blocks.append(
                "Typecheck failed (SLIME_TYPECHECK_CMD exited "
                + str(tc[0])
                + "): the patch references something that does not resolve in "
                "the repo — often a hallucinated attachment point. Fix the "
                "reference. If it should exist but doesn't yet, it is new work, "
                "not an anchor — go back and add it to the corridor's Goal "
                "Frontier.\n\n"
                + tc[1][:1500]
            )
        deps = new_dependencies(cwd)
        if deps:
            blocks.append(
                "New dependency added to "
                + PUBSPEC
                + ": "
                + ", ".join(deps)
                + ". Each must be justified by the current corridor — keep it "
                "(and say why) or remove it before finishing."
            )
        rc = run_check(cwd)
        if rc is not None and rc != 0 and not pruned_touched(cwd):
            blocks.append(
                "Stopping with a failing check: SLIME_TEST_CMD exited "
                + str(rc)
                + ". Don't finish silently on red — either make the check pass, "
                "or, if you abandoned a design that led here, record it in "
                ".slime/PRUNED.md (/slime-prune) so the next round doesn't retry "
                "it. (Detected via git status on .slime/PRUNED.md, not a session "
                "boundary.)"
            )
        out_corr = out_of_corridor_files(cwd) if strict_corridor_enabled() else []
        if out_corr:
            blocks.append(
                "Out-of-corridor product-code edits detected: "
                + ", ".join(out_corr[:10])
                + ". This increases semantic displacement beyond the current "
                "Meeting Corridor. Either move the change back inside the "
                "corridor, or update .slime/corridor.md with the new evidence "
                "before finishing."
            )
        if strict_corridor_enabled():
            # Emptying or deleting .slime/corridor.md used to make the
            # out-of-corridor check vacuously pass (.slime/ writes are always
            # exempt at PreToolUse, and Bash edits are never gated), so scope
            # creep could be laundered by clearing the Paths list at the end.
            # Product changes with no valid corridor are the same evidence gap
            # the PreToolUse gate denies on.
            problem = corridor_problem(cwd)
            if problem:
                touched, new_files = changed_paths(cwd)
                product = [
                    n
                    for n in touched + new_files
                    if not n.startswith(".slime/")
                    and os.path.basename(n) not in META_BASENAMES
                ]
                if product:
                    blocks.append(
                        "Product code changed but " + problem + ", so the "
                        "out-of-corridor check has nothing to check against. "
                        "Restore or complete .slime/corridor.md (id + '## Paths') "
                        "to cover this session's changes before finishing: "
                        + ", ".join(product[:10])
                    )

    report = l3_report(cwd)
    if blocks:
        print(json.dumps({"decision": "block", "reason": "\n\n".join(blocks) + "\n\n" + report}))
        sys.exit(0)
    print(json.dumps({"systemMessage": report}))
    sys.exit(0)


def main():
    data = read_input()
    event = data.get("hook_event_name")
    if event == "PreToolUse":
        corridor_gate(data)
    elif event == "Stop":
        stop(data)
    sys.exit(0)


if __name__ == "__main__":
    main()

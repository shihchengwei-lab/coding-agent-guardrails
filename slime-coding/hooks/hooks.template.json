{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"__SLIME_HOME__\"/bin/prune-inject"
          },
          {
            "type": "command",
            "command": "python3 \"__SLIME_HOME__\"/bin/patch-cost"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"__SLIME_HOME__\"/bin/prune-inject"
          },
          {
            "type": "command",
            "command": "python3 \"__SLIME_HOME__\"/bin/patch-cost"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"__SLIME_HOME__\"/bin/patch-cost"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"__SLIME_HOME__\"/bin/patch-cost"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"__SLIME_HOME__\"/bin/patch-cost"
          }
        ]
      }
    ]
  }
}
